    reg[dst] = trunc_width(reg[lhs] and reg[rhs], width) # and 结果按目标宽度掩码
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 iand 指令

instr ptrmask(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # ruoke 指针 mask 处理器，按 64 位地址 bit 做 and
  opcode alias [0x2d4] # ptrmask 使用从 iand 挪出的独立 opcode，保持 ruoke 总 opcode 数为 1000
  decoded_width = 16 # ptrmask 包含三个寄存器操作数和位宽操作数，使用 16 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[lhs] and reg[rhs], width) # 指针地址 bit 与 mask 相与后仍按指针 bit 写回 x 寄存器
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 ptrmask 指令

