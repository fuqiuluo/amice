  } # 结束语义块
} # 结束 vm_ret 指令

instr ret(src: vreg<i64>) { # 函数返回处理器
  opcode alias [0x22a, 0x37b, 0x0e4, 0x235, 0x386, 0x0ef, 0x240, 0x391] # ret 的 ruoke 操作码别名第 1 组
  opcode alias [0x0fa, 0x24b, 0x39c, 0x105, 0x256, 0x3a7, 0x110, 0x261] # ret 的 ruoke 操作码别名第 2 组
  opcode alias [0x3b2, 0x11b, 0x26c, 0x3bd, 0x126, 0x277, 0x3c8, 0x131] # ret 的 ruoke 操作码别名第 3 组
  opcode alias [0x282, 0x3d3, 0x13c, 0x28d, 0x3de, 0x147, 0x298] # ret 的 ruoke 操作码别名第 4 组
  decoded_width = 4 # ret 只需要 opcode 和一个寄存器操作数，使用 4 字节 record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[ret0] = reg[src] # 返回值归一化写入 abi.vm 声明的第 0 个返回槽
