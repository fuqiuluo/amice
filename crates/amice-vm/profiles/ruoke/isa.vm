instr ixor(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数 xor 处理器
  opcode alias [0x0a7, 0x1f8, 0x349, 0x0b2, 0x203, 0x354, 0x0bd, 0x20e] # ixor 的 ruoke 操作码别名第 1 组
  opcode alias [0x35f, 0x0c8, 0x219, 0x36a, 0x0d3, 0x224, 0x375, 0x0de] # ixor 的 ruoke 操作码别名第 2 组
  opcode alias [0x22f, 0x380, 0x0e9, 0x23a, 0x38b, 0x0f4, 0x245, 0x396] # ixor 的 ruoke 操作码别名第 3 组
