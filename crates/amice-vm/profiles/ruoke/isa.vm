  opcode alias [0x02b, 0x17c, 0x2cd, 0x036, 0x187, 0x2d8, 0x041] # ilshr 的 ruoke 操作码别名第 4 组
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[lhs] >>u reg[rhs], width) # 无符号右移结果按目标宽度掩码
    pc = next # 执行继续到下一条字节码指令
