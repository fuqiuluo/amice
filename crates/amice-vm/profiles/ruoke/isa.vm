instr ismax(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数有符号最大值处理器
  opcode alias [0x114] # ismax 复用从 mov 挪出的 ruoke 别名，保持总 opcode 数不变
