instr mov_imm(dst: vreg<i64>, imm: imm<u64>, width: imm<u8>) { # 将立即数物化到 VM 的 x 寄存器
  opcode alias [0x001] # mov_imm 保留入口主操作码，把更多操作码预算让给浮点处理器
  opcode alias [0x2b9] # mov_imm 的 ruoke 操作码别名第 2 组
  opcode alias [0x189] # mov_imm 的 ruoke 操作码别名第 3 组
  opcode alias [0x059] # mov_imm 的 ruoke 操作码别名第 4 组
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(imm, width) # 立即数字段按请求的整数宽度截断或掩码
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 mov_imm 指令

instr const_load(dst: vreg<i64>, index: const_pool_index, width: imm<u8>) { # 从加密常量池按索引物化常量
  opcode alias [0x311, 0x07a, 0x1cb, 0x31c, 0x085, 0x1d6, 0x327, 0x090] # const_load 保留 8 个别名，把预算让给浮点转换处理器
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = const_pool[index] # runtime 先解密常量池，再按 index 读取对应常量
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 const_load 指令

instr mov(dst: vreg<i64>, src: vreg<i64>, width: imm<u8>) { # 将一个 VM x 寄存器复制到另一个寄存器
  opcode alias [0x12a, 0x27b, 0x3cc, 0x135, 0x286] # mov 的 ruoke 操作码别名第 1 组，继续挪出别名给 tls_addr/global_addr
  opcode alias [0x3e2, 0x14b, 0x29c, 0x005, 0x156, 0x2a7] # mov 的 ruoke 操作码别名第 2 组，继续挪出别名给乘法溢出 intrinsic
  decoded_width = 8 # mov 的 opcode 和三个短操作数固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[src], width) # 源寄存器低位复制到目标寄存器并按 width 掩码
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 mov 指令

instr tls_addr(dst: vreg<i64>, src: vreg<i64>, width: imm<u8>) { # ruoke 线程本地地址包装处理器，保留运行时指针值
  opcode alias [0x140] # tls_addr 使用从 mov 挪出的独立 opcode，保持 ruoke 总 opcode 数为 1000
  decoded_width = 8 # tls_addr 的 opcode 和三个短操作数固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[src], width) # threadlocal.address 返回同一运行时指针 bit
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 tls_addr 指令

instr global_addr(dst: vreg<i64>, src: vreg<i64>, width: imm<u8>) { # ruoke 普通全局符号地址包装处理器，保留运行时指针值
  opcode alias [0x3d7] # global_addr 使用从 mov 挪出的独立 opcode，保持 ruoke 总 opcode 数为 1000
  decoded_width = 8 # global_addr 的 opcode 和三个短操作数固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[src], width) # native thunk 返回的全局地址 bit 复制到 VM x 寄存器
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 global_addr 指令

instr iadd(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数加法处理器
  opcode alias [0x161, 0x2b2, 0x01b, 0x16c, 0x2bd, 0x026, 0x177, 0x2c8] # iadd 的 ruoke 操作码别名第 1 组
  opcode alias [0x031, 0x182, 0x2d3, 0x03c, 0x18d, 0x2de, 0x047, 0x198] # iadd 的 ruoke 操作码别名第 2 组
  opcode alias [0x2e9, 0x052, 0x1a3, 0x2f4, 0x05d, 0x1ae, 0x2ff, 0x068] # iadd 的 ruoke 操作码别名第 3 组
  opcode alias [0x1b9, 0x30a, 0x073, 0x1c4, 0x315, 0x07e, 0x1cf, 0x320] # iadd 的 ruoke 操作码别名第 4 组
  decoded_width = 16 # iadd 使用 16 字节 record，给 ruoke 多字节 opcode alias 留出余量
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[lhs] + reg[rhs], width) # 加法结果按目标宽度掩码
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 iadd 指令

instr iadd_xor(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, xor_rhs: vreg<i64>, width: imm<u8>) { # 超级指令：整数加法后立即异或
  opcode alias [0x2a6] # iadd_xor 从 fake_nop 干扰预算中挪用 1 个 ruoke opcode
  decoded_width = 48 # iadd_xor 有四个寄存器操作数和位宽操作数，因此使用 48 字节 record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[lhs] + reg[rhs] xor reg[xor_rhs], width) # 组合加法和 xor，避免产生可见中间寄存器
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 iadd_xor 超级指令

instr isub(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数减法处理器
  opcode alias [0x089, 0x1da, 0x32b, 0x094, 0x1e5, 0x336, 0x09f, 0x1f0] # isub 的 ruoke 操作码别名第 1 组
  opcode alias [0x341, 0x0aa, 0x1fb, 0x34c, 0x0b5, 0x206, 0x357, 0x0c0] # isub 的 ruoke 操作码别名第 2 组
  opcode alias [0x211, 0x362, 0x0cb, 0x21c, 0x36d, 0x0d6, 0x227, 0x378] # isub 的 ruoke 操作码别名第 3 组
  opcode alias [0x0e1, 0x232, 0x383, 0x0ec, 0x23d, 0x38e, 0x0f7, 0x248] # isub 的 ruoke 操作码别名第 4 组
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[lhs] - reg[rhs], width) # 减法结果按目标宽度掩码
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 isub 指令

instr imul(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数乘法处理器
  opcode alias [0x399, 0x102, 0x253, 0x3a4, 0x10d, 0x25e, 0x3af, 0x118] # imul 的 ruoke 操作码别名第 1 组
  opcode alias [0x269, 0x3ba, 0x123, 0x274, 0x3c5, 0x12e, 0x27f, 0x3d0] # imul 的 ruoke 操作码别名第 2 组
  opcode alias [0x139, 0x28a, 0x3db, 0x144, 0x295, 0x3e6, 0x14f, 0x2a0] # imul 的 ruoke 操作码别名第 3 组
  opcode alias [0x009, 0x15a, 0x2ab, 0x014, 0x165, 0x2b6, 0x01f, 0x170] # imul 的 ruoke 操作码别名第 4 组
