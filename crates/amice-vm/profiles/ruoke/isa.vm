  opcode alias [0x2ec, 0x055, 0x1a6, 0x2f7, 0x060, 0x1b1, 0x302] # vm_call 的 ruoke 操作码别名第 4 组
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[lr] = next # 调用前把返回字节码 PC 写入 runtime.vm 定义的 lr 别名
    pc = target # 执行跳转到目标字节码标签
  } # 结束语义块
} # 结束 vm_call 指令

instr vm_ret() { # VM 内部返回处理器
  opcode alias [0x06b, 0x1bc, 0x30d, 0x076, 0x1c7, 0x318, 0x081, 0x1d2] # vm_ret 的 ruoke 操作码别名第 1 组
  opcode alias [0x323, 0x08c, 0x1dd, 0x32e, 0x097, 0x1e8, 0x339, 0x0a2] # vm_ret 的 ruoke 操作码别名第 2 组
  opcode alias [0x1f3, 0x344, 0x0ad, 0x1fe, 0x34f, 0x0b8, 0x209, 0x35a] # vm_ret 的 ruoke 操作码别名第 3 组
