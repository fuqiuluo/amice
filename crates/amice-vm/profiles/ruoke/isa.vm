instr cmpxchg(old: vreg<i64>, success: vreg<i1>, ptr: vreg<ptr>, cmp: vreg<i64>, new: vreg<i64>, width: imm<u8>, success_ordering: imm<u8>, failure_ordering: imm<u8>) { # 标量 compare-exchange 处理器
  opcode alias [0x2b1] # cmpxchg 从 fake_nop 干扰预算中挪用 1 个 ruoke 别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    cmpxchg(reg[old], reg[success], reg[ptr], reg[cmp], reg[new], width, success_ordering, failure_ordering) # 运行时生成 LLVM cmpxchg 并写回旧值和成功标志
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 cmpxchg 指令

instr volatile_cmpxchg(old: vreg<i64>, success: vreg<i1>, ptr: vreg<ptr>, cmp: vreg<i64>, new: vreg<i64>, width: imm<u8>, success_ordering: imm<u8>, failure_ordering: imm<u8>) { # 标量 volatile compare-exchange 处理器
  opcode alias [0x3cb] # volatile_cmpxchg 从 call_native 高预算别名中挪用 1 个 ruoke opcode，保持总数 1000
  semantic { # 处理语义由 AMICE 校验器静态识别
    volatile_cmpxchg(reg[old], reg[success], reg[ptr], reg[cmp], reg[new], width, success_ordering, failure_ordering) # 运行时生成带 volatile 标记的 LLVM cmpxchg
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 volatile_cmpxchg 指令

instr fence(ordering: imm<u8>) { # LLVM atomic fence 处理器
  opcode alias [0x00f] # fence 从 fake_nop 干扰预算中挪用 1 个 ruoke 别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    fence(ordering) # 运行时生成真正的 LLVM fence 指令
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 fence 指令

instr gep(dst: vreg<ptr>, base: vreg<ptr>, offset: imm<u64>) { # 常量字节偏移 GEP 处理器
  opcode alias [0x1a9, 0x2fa, 0x063, 0x1b4, 0x305, 0x06e, 0x1bf, 0x310] # gep 的 ruoke 操作码别名第 1 组
  opcode alias [0x079, 0x1ca, 0x31b, 0x084, 0x1d5, 0x326, 0x08f, 0x1e0] # gep 的 ruoke 操作码别名第 2 组
  opcode alias [0x331, 0x09a, 0x1eb, 0x33c, 0x0a5, 0x1f6, 0x347, 0x0b0] # gep 的 ruoke 操作码别名第 3 组
  opcode alias [0x201, 0x352, 0x0bb, 0x20c, 0x35d, 0x0c6, 0x217] # gep 的 ruoke 操作码别名第 4 组
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = reg[base] + offset # 运行时计算按字节寻址的指针算术
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 gep 指令

instr gep_load(dst: vreg<i64>, base: vreg<ptr>, offset: imm<u64>, width: imm<u8>) { # 超级指令：常量字节偏移 GEP 后立即读取标量
  opcode alias [0x2dd] # gep_load 从 fake_nop 干扰预算中挪用 1 个 ruoke opcode
  decoded_width = 32 # gep_load 包含 64 位 offset 操作数，因此使用 32 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = load_width(reg[base] + offset, width) # 先计算 base+offset，再按 width 从该地址读取标量
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 gep_load 超级指令

instr load_iadd(dst: vreg<i64>, ptr: vreg<ptr>, addend: vreg<i64>, width: imm<u8>) { # 超级指令：标量 load 后立即执行整数加法
  opcode alias [0x18c] # load_iadd 从 fake_nop 干扰预算中挪用 1 个 ruoke opcode
  decoded_width = 32 # load_iadd 包含三个寄存器操作数和位宽操作数，使用 32 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(load_width(reg[ptr], width) + reg[addend], width) # 先从 ptr 读取标量，再与 addend 做整数加法
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 load_iadd 超级指令

instr call_native(callee: imm<u16>, argc: imm<u8>, arg0: vreg<i64>, arg1: vreg<i64>, arg2: vreg<i64>, arg3: vreg<i64>, arg4: vreg<i64>, arg5: vreg<i64>, arg6: vreg<i64>, arg7: vreg<i64>, ret_count: imm<u8>, ret0: vreg<i64>, ret0_width: imm<u8>, ret1: vreg<i64>, ret1_width: imm<u8>, ret2: vreg<i64>, ret2_width: imm<u8>, ret3: vreg<i64>, ret3_width: imm<u8>, ret4: vreg<i64>, ret4_width: imm<u8>, ret5: vreg<i64>, ret5_width: imm<u8>, ret6: vreg<i64>, ret6_width: imm<u8>, ret7: vreg<i64>, ret7_width: imm<u8>) { # 直接原生调用桥接处理器，record 固定容纳八个返回槽
  opcode alias [0x368, 0x0d1, 0x222, 0x373, 0x0dc, 0x22d, 0x37e, 0x0e7] # call_native 的 ruoke 操作码别名第 1 组
  opcode alias [0x238, 0x389, 0x0f2, 0x243, 0x394, 0x0fd, 0x24e, 0x39f] # call_native 的 ruoke 操作码别名第 2 组
  opcode alias [0x108, 0x259, 0x3aa, 0x113, 0x264, 0x3b5, 0x11e, 0x26f] # call_native 的 ruoke 操作码别名第 3 组
  opcode alias [0x3c0, 0x129, 0x27a] # call_native 的 ruoke 操作码别名第 4 组，3 个别名已挪给 volatile 动态内存 handler，1 个别名已挪给 volatile_cmpxchg
  decoded_width = 64 # call_native 操作数字段最多，使用最大 64 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[ret0] = call_table[callee].ret0(reg[arg0], reg[arg1], reg[arg2], reg[arg3], reg[arg4], reg[arg5], reg[arg6], reg[arg7], argc, ret_count, ret0_width) # 运行时通过生成的原生调用桥表写回第 0 个返回槽
    reg[ret1] = call_table[callee].ret1(ret_count, ret1_width) # 若 ret_count 大于 1，运行时写回第 1 个返回槽
    reg[ret2] = call_table[callee].ret2(ret_count, ret2_width) # 若 ret_count 大于 2，运行时写回第 2 个返回槽
    reg[ret3] = call_table[callee].ret3(ret_count, ret3_width) # 若 ret_count 大于 3，运行时写回第 3 个返回槽
    reg[ret4] = call_table[callee].ret4(ret_count, ret4_width) # 若 ret_count 大于 4，运行时写回第 4 个返回槽
    reg[ret5] = call_table[callee].ret5(ret_count, ret5_width) # 若 ret_count 大于 5，运行时写回第 5 个返回槽
    reg[ret6] = call_table[callee].ret6(ret_count, ret6_width) # 若 ret_count 大于 6，运行时写回第 6 个返回槽
    reg[ret7] = call_table[callee].ret7(ret_count, ret7_width) # 若 ret_count 大于 7，运行时写回第 7 个返回槽
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 call_native 指令

instr read_cycle(dst: vreg<i64>, width: imm<u8>) { # 读取 LLVM readcyclecounter 计数器并写入 VM x 寄存器
  opcode alias [0x261] # 从 ret 的 ruoke 高预算别名挪用 1 个 opcode，总唯一 opcode 数保持 1000
  decoded_width = 8 # read_cycle 的 opcode、目标寄存器和位宽固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = read_counter(cycle) # runtime 调用 llvm.readcyclecounter 并取得 i64 计数值
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 read_cycle 指令

instr read_steady(dst: vreg<i64>, width: imm<u8>) { # 读取 LLVM readsteadycounter 计数器并写入 VM x 寄存器
  opcode alias [0x131] # 从 ret 的 ruoke 高预算别名挪用 1 个 opcode，总唯一 opcode 数保持 1000
  decoded_width = 8 # read_steady 的 opcode、目标寄存器和位宽固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = read_counter(steady) # runtime 调用 llvm.readsteadycounter 并取得 i64 计数值
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 read_steady 指令

instr sideeffect() { # LLVM sideeffect 处理器，用于保留优化器必须看到的副作用屏障
  opcode alias [0x110] # 从 ret 的 ruoke 高预算别名挪用 1 个 opcode，总唯一 opcode 数保持 1000
  decoded_width = 4 # sideeffect 没有操作数，使用最小 4 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    side_effect() # runtime 调用 llvm.sideeffect intrinsic，保留可见副作用
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 sideeffect 指令

instr stacksave(dst: vreg<ptr>) { # LLVM stacksave 处理器，用于保存当前栈恢复点
  opcode alias [0x256] # 从 ret 的 ruoke 高预算别名挪用 1 个 opcode，总唯一 opcode 数保持 1000
  decoded_width = 8 # stacksave 只有目标寄存器 operand，使用 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = stack_save() # runtime 调用 llvm.stacksave 并把返回指针写入 VM x 寄存器
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 stacksave 指令

instr stackrestore(ptr: vreg<ptr>) { # LLVM stackrestore 处理器，用于恢复到此前保存的栈状态
  opcode alias [0x3a7] # 从 ret 的 ruoke 高预算别名挪用 1 个 opcode，总唯一 opcode 数保持 1000
  decoded_width = 8 # stackrestore 只有一个指针寄存器 operand，使用 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    stack_restore(reg[ptr]) # runtime 调用 llvm.stackrestore，恢复 stacksave 返回的栈状态
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 stackrestore 指令

instr clear_cache(start: vreg<ptr>, end: vreg<ptr>) { # LLVM clear_cache 处理器，用于刷新一段代码地址区间的指令缓存
  opcode alias [0x105] # 从 ret 的 ruoke 高预算别名挪用 1 个 opcode，总唯一 opcode 数保持 1000
  decoded_width = 8 # clear_cache 包含两个指针寄存器 operand，使用 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    clear_cache(reg[start], reg[end]) # runtime 调用 llvm.clear_cache，刷新 start 到 end 的地址区间
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 clear_cache 指令

instr fake_nop() { # 假指令处理器，用于插入不改变 VM 状态的干扰字节码
  opcode alias [0x176] # fake_nop 第 1 组剩余别名，其余 22 个已挪给 atomicrmw、整数 intrinsic、funnel shift、cmpxchg、fence 和超级 handler
  decoded_width = 4 # fake_nop 只有 opcode，使用最小 4 字节 record
  semantic { # 处理语义由 AMICE 校验器静态识别
    state = unchanged # 该指令不读取或写入任何 VM 数据寄存器
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 fake_nop 指令

instr br(target: label) { # 无条件分支处理器
  opcode alias [0x2fe, 0x067, 0x1b8, 0x309, 0x072, 0x1c3, 0x314, 0x07d] # br 的 ruoke 操作码别名第 1 组
  opcode alias [0x1ce, 0x31f, 0x088, 0x1d9, 0x32a, 0x093, 0x1e4, 0x335] # br 的 ruoke 操作码别名第 2 组
  opcode alias [0x09e, 0x1ef, 0x340, 0x0a9, 0x1fa, 0x34b, 0x0b4, 0x205] # br 的 ruoke 操作码别名第 3 组
  opcode alias [0x356, 0x0bf, 0x210, 0x361, 0x0ca, 0x21b] # br 的 ruoke 操作码别名第 4 组，0x36c 已挪给 atomic_rmw_fminimum
  semantic { # 处理语义由 AMICE 校验器静态识别
    pc = target # 执行跳转到目标字节码标签
  } # 结束语义块
} # 结束 br 指令

instr br_if(cond: vreg<i1>, then_pc: label, else_pc: label) { # 条件分支处理器
  opcode alias [0x0d5, 0x226, 0x377, 0x0e0, 0x231, 0x382, 0x0eb, 0x23c] # br_if 的 ruoke 操作码别名第 1 组
  opcode alias [0x38d, 0x0f6, 0x247, 0x398, 0x101, 0x252, 0x3a3, 0x10c] # br_if 的 ruoke 操作码别名第 2 组
  opcode alias [0x25d, 0x3ae, 0x117, 0x268, 0x3b9, 0x122, 0x273, 0x3c4] # br_if 的 ruoke 操作码别名第 3 组，尾部 7 个别名已挪给 volatile atomicrmw
  semantic { # 处理语义由 AMICE 校验器静态识别
    pc = select(reg[cond], then_pc, else_pc) # 条件寄存器选择下一条字节码标签
  } # 结束语义块
} # 结束 br_if 指令

instr vm_call(target: label) { # VM 内部调用处理器
  opcode alias [0x294, 0x3e5, 0x14e, 0x29f, 0x008, 0x159, 0x2aa, 0x013] # vm_call 的 ruoke 操作码别名第 1 组
  opcode alias [0x164, 0x2b5, 0x01e, 0x16f, 0x2c0, 0x029, 0x17a, 0x2cb] # vm_call 的 ruoke 操作码别名第 2 组
  opcode alias [0x034, 0x185, 0x2d6, 0x03f, 0x190, 0x2e1, 0x04a, 0x19b] # vm_call 的 ruoke 操作码别名第 3 组
  opcode alias [0x1a6] # vm_call 的 ruoke 操作码别名第 4 组，4 个别名已挪给扩展 atomicrmw，2 个别名已挪给 volatile atomic
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[lr] = next # 调用前把返回字节码 PC 写入 runtime.vm 定义的 lr 别名
    pc = target # 执行跳转到目标字节码标签
  } # 结束语义块
} # 结束 vm_call 指令

instr vm_ret() { # VM 内部返回处理器
  opcode alias [0x06b, 0x1bc, 0x30d, 0x076, 0x1c7, 0x318, 0x081, 0x1d2] # vm_ret 的 ruoke 操作码别名第 1 组
  opcode alias [0x323, 0x08c, 0x1dd, 0x32e, 0x097, 0x1e8, 0x339, 0x0a2] # vm_ret 的 ruoke 操作码别名第 2 组
  opcode alias [0x1f3, 0x344, 0x0ad, 0x1fe, 0x34f, 0x0b8, 0x209, 0x35a] # vm_ret 的 ruoke 操作码别名第 3 组，尾部 7 个别名已挪给 volatile atomicrmw
  semantic { # 处理语义由 AMICE 校验器静态识别
    pc = reg[lr] # 从 lr 恢复调用点之后的字节码 PC
  } # 结束语义块
} # 结束 vm_ret 指令

instr unreachable() { # LLVM unreachable 终结处理器
  opcode alias [0x298] # 从 ret 的 ruoke 别名预算挪用 1 个 opcode，总唯一 opcode 数保持 1000
  decoded_width = 4 # 无操作数指令仍占用最小 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    unreachable # 执行到这里时生成 LLVM unreachable，保留源 IR 的未定义行为路径
  } # 结束语义块
} # 结束 unreachable 指令

instr trap() { # LLVM trap intrinsic 终结处理器
  opcode alias [0x147] # 从 ret 的 ruoke 别名预算挪用 1 个 opcode，总唯一 opcode 数保持 1000
  decoded_width = 4 # 无操作数 trap 指令仍占用最小 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    trap # 执行到这里时 runtime 调用 LLVM trap intrinsic 并终止控制流
  } # 结束语义块
} # 结束 trap 指令

instr ret(src: vreg<i64>) { # 函数返回处理器
  opcode alias [0x22a, 0x37b, 0x0e4, 0x235, 0x386, 0x0ef, 0x240, 0x391] # ret 的 ruoke 操作码别名第 1 组
  opcode alias [0x0fa, 0x24b, 0x39c] # ret 的 ruoke 操作码别名第 2 组，13 个别名已挪给 volatile atomicrmw、readcounter、sideeffect、stack intrinsic 和 clear_cache
  decoded_width = 4 # ret 只需要 opcode 和一个寄存器操作数，使用 4 字节 record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[ret0] = reg[src] # 返回值归一化写入 abi.vm 声明的第 0 个返回槽
    pc = return # 分派循环在该指令后退出
  } # 结束语义块
} # 结束 ret 指令
