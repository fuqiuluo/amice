} # 结束 ilshr 指令

instr iashr(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数算术右移处理器
  opcode alias [0x192, 0x2e3, 0x04c, 0x19d, 0x2ee, 0x057, 0x1a8, 0x2f9] # iashr 的 ruoke 操作码别名第 1 组
  opcode alias [0x062, 0x1b3, 0x304, 0x06d, 0x1be, 0x30f, 0x078, 0x1c9] # iashr 的 ruoke 操作码别名第 2 组
  opcode alias [0x31a, 0x083, 0x1d4, 0x325, 0x08e, 0x1df, 0x330, 0x099] # iashr 的 ruoke 操作码别名第 3 组
  opcode alias [0x1ea, 0x33b, 0x0a4, 0x1f5, 0x346, 0x0af, 0x200] # iashr 的 ruoke 操作码别名第 4 组
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(sign_extend(reg[lhs], width) >>s reg[rhs], width) # lhs 先按 width 符号扩展再做有符号右移
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 iashr 指令

instr ctpop(dst: vreg<i64>, src: vreg<i64>, width: imm<u8>) { # 整数 bit 计数处理器
  opcode alias [0x2c7] # ctpop 从 fake_nop 干扰预算中挪用 1 个 ruoke 别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = int_unary(ctpop, reg[src], width) # 运行时统计 src 在 width 范围内置位 bit 的数量
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 ctpop 指令

instr bswap(dst: vreg<i64>, src: vreg<i64>, width: imm<u8>) { # 整数字节序反转处理器
  opcode alias [0x030] # bswap 从 fake_nop 干扰预算中挪用 1 个 ruoke 别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = int_unary(bswap, reg[src], width) # 运行时按 width 对 src 做字节序反转
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 bswap 指令

instr bitreverse(dst: vreg<i64>, src: vreg<i64>, width: imm<u8>) { # 整数 bit 顺序反转处理器
  opcode alias [0x181] # bitreverse 从 fake_nop 干扰预算中挪用 1 个 ruoke 别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = int_unary(bitreverse, reg[src], width) # 运行时按 width 对 src 做 bit 顺序反转
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 bitreverse 指令

instr fshl(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, third: vreg<i64>, width: imm<u8>) { # 整数 funnel 左移处理器
  opcode alias [0x2d2] # fshl 从 fake_nop 干扰预算中挪用 1 个 ruoke 别名
  decoded_width = 48 # fshl 故意使用 48 字节 record，覆盖中等宽度 decoded instruction
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = int_ternary(fshl, reg[lhs], reg[rhs], reg[third], width) # 拼接 lhs/rhs 后执行 LLVM fshl 语义
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 fshl 指令

