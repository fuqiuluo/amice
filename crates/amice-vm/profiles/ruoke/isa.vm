instr iand(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数 and 处理器
  opcode alias [0x266, 0x3b7, 0x120, 0x271, 0x3c2, 0x12b, 0x27c, 0x3cd] # iand 的 ruoke 操作码别名第 1 组
  opcode alias [0x136, 0x287, 0x3d8, 0x141, 0x292, 0x3e3, 0x14c, 0x29d] # iand 的 ruoke 操作码别名第 2 组
  opcode alias [0x006, 0x157, 0x2a8, 0x011, 0x162, 0x2b3, 0x01c, 0x16d] # iand 的 ruoke 操作码别名第 3 组
  opcode alias [0x2be, 0x027, 0x178, 0x2c9, 0x032, 0x183] # iand 的 ruoke 操作码别名第 4 组，挪出一个 opcode 给 ptrmask
