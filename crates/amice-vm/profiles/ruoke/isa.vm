instr ishl(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数逻辑左移处理器
  opcode alias [0x1fc, 0x34d, 0x0b6, 0x207, 0x358, 0x0c1, 0x212, 0x363] # ishl 的 ruoke 操作码别名第 1 组
  opcode alias [0x0cc, 0x21d, 0x36e, 0x0d7, 0x228, 0x379, 0x0e2, 0x233] # ishl 的 ruoke 操作码别名第 2 组
  opcode alias [0x384, 0x0ed, 0x23e, 0x38f, 0x0f8, 0x249, 0x39a, 0x103] # ishl 的 ruoke 操作码别名第 3 组
  opcode alias [0x254, 0x3a5, 0x10e, 0x25f, 0x3b0, 0x119, 0x26a] # ishl 的 ruoke 操作码别名第 4 组
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[lhs] << reg[rhs], width) # 移位结果按目标宽度掩码
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 ishl 指令

instr ilshr(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数逻辑右移处理器
  opcode alias [0x3bb, 0x124, 0x275, 0x3c6, 0x12f, 0x280, 0x3d1, 0x13a] # ilshr 的 ruoke 操作码别名第 1 组
  opcode alias [0x28b, 0x3dc, 0x145, 0x296, 0x3e7, 0x150, 0x2a1, 0x00a] # ilshr 的 ruoke 操作码别名第 2 组
