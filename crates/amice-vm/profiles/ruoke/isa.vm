  opcode alias [0x192, 0x2e3, 0x04c, 0x19d, 0x2ee, 0x057, 0x1a8, 0x2f9] # iashr 的 ruoke 操作码别名第 1 组
  opcode alias [0x062, 0x1b3, 0x304, 0x06d, 0x1be, 0x30f, 0x078, 0x1c9] # iashr 的 ruoke 操作码别名第 2 组
