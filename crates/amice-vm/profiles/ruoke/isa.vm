  opcode alias [0x0b9, 0x20a, 0x35b, 0x0c4, 0x215, 0x366, 0x0cf, 0x220] # isdiv 的 ruoke 操作码别名第 2 组
  opcode alias [0x371, 0x0da, 0x22b, 0x37c, 0x0e5, 0x236, 0x387, 0x0f0] # isdiv 的 ruoke 操作码别名第 3 组
