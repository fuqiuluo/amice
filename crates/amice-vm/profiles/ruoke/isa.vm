instr br_if(cond: vreg<i1>, then_pc: label, else_pc: label) { # 条件分支处理器
  opcode alias [0x0d5, 0x226, 0x377, 0x0e0, 0x231, 0x382, 0x0eb, 0x23c] # br_if 的 ruoke 操作码别名第 1 组
  opcode alias [0x38d, 0x0f6, 0x247, 0x398, 0x101, 0x252, 0x3a3, 0x10c] # br_if 的 ruoke 操作码别名第 2 组
  opcode alias [0x25d, 0x3ae, 0x117, 0x268, 0x3b9, 0x122, 0x273, 0x3c4] # br_if 的 ruoke 操作码别名第 3 组
  opcode alias [0x12d, 0x27e, 0x3cf, 0x138, 0x289, 0x3da, 0x143] # br_if 的 ruoke 操作码别名第 4 组
  semantic { # 处理语义由 AMICE 校验器静态识别
    pc = select(reg[cond], then_pc, else_pc) # 条件寄存器选择下一条字节码标签
  } # 结束语义块
} # 结束 br_if 指令

instr vm_call(target: label) { # VM 内部调用处理器
  opcode alias [0x294, 0x3e5, 0x14e, 0x29f, 0x008, 0x159, 0x2aa, 0x013] # vm_call 的 ruoke 操作码别名第 1 组
  opcode alias [0x164, 0x2b5, 0x01e, 0x16f, 0x2c0, 0x029, 0x17a, 0x2cb] # vm_call 的 ruoke 操作码别名第 2 组
