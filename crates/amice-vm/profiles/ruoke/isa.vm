instr gep(dst: vreg<ptr>, base: vreg<ptr>, offset: imm<u64>) { # 常量字节偏移 GEP 处理器
  opcode alias [0x1a9, 0x2fa, 0x063, 0x1b4, 0x305, 0x06e, 0x1bf, 0x310] # gep 的 ruoke 操作码别名第 1 组
  opcode alias [0x079, 0x1ca, 0x31b, 0x084, 0x1d5, 0x326, 0x08f, 0x1e0] # gep 的 ruoke 操作码别名第 2 组
  opcode alias [0x331, 0x09a, 0x1eb, 0x33c, 0x0a5, 0x1f6, 0x347, 0x0b0] # gep 的 ruoke 操作码别名第 3 组
  opcode alias [0x201, 0x352, 0x0bb, 0x20c, 0x35d, 0x0c6, 0x217] # gep 的 ruoke 操作码别名第 4 组
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = reg[base] + offset # 运行时计算按字节寻址的指针算术
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 gep 指令

instr gep_load(dst: vreg<i64>, base: vreg<ptr>, offset: imm<u64>, width: imm<u8>) { # 超级指令：常量字节偏移 GEP 后立即读取标量
  opcode alias [0x2dd] # gep_load 从 fake_nop 干扰预算中挪用 1 个 ruoke opcode
  decoded_width = 32 # gep_load 包含 64 位 offset 操作数，因此使用 32 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = load_width(reg[base] + offset, width) # 先计算 base+offset，再按 width 从该地址读取标量
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 gep_load 超级指令

instr load_iadd(dst: vreg<i64>, ptr: vreg<ptr>, addend: vreg<i64>, width: imm<u8>) { # 超级指令：标量 load 后立即执行整数加法
  opcode alias [0x18c] # load_iadd 从 fake_nop 干扰预算中挪用 1 个 ruoke opcode
  decoded_width = 32 # load_iadd 包含三个寄存器操作数和位宽操作数，使用 32 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(load_width(reg[ptr], width) + reg[addend], width) # 先从 ptr 读取标量，再与 addend 做整数加法
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 load_iadd 超级指令

instr call_native(callee: imm<u16>, argc: imm<u8>, arg0: vreg<i64>, arg1: vreg<i64>, arg2: vreg<i64>, arg3: vreg<i64>, arg4: vreg<i64>, arg5: vreg<i64>, arg6: vreg<i64>, arg7: vreg<i64>, ret_count: imm<u8>, ret0: vreg<i64>, ret0_width: imm<u8>, ret1: vreg<i64>, ret1_width: imm<u8>, ret2: vreg<i64>, ret2_width: imm<u8>, ret3: vreg<i64>, ret3_width: imm<u8>, ret4: vreg<i64>, ret4_width: imm<u8>, ret5: vreg<i64>, ret5_width: imm<u8>, ret6: vreg<i64>, ret6_width: imm<u8>, ret7: vreg<i64>, ret7_width: imm<u8>) { # 直接原生调用桥接处理器，record 固定容纳八个返回槽
  opcode alias [0x368, 0x0d1, 0x222, 0x373, 0x0dc, 0x22d, 0x37e, 0x0e7] # call_native 的 ruoke 操作码别名第 1 组
  opcode alias [0x238, 0x389, 0x0f2, 0x243, 0x394, 0x0fd, 0x24e, 0x39f] # call_native 的 ruoke 操作码别名第 2 组
  opcode alias [0x108, 0x259, 0x3aa, 0x113, 0x264, 0x3b5, 0x11e, 0x26f] # call_native 的 ruoke 操作码别名第 3 组
  opcode alias [0x3c0, 0x129, 0x27a, 0x3cb, 0x134, 0x285, 0x3d6] # call_native 的 ruoke 操作码别名第 4 组
  decoded_width = 64 # call_native 操作数字段最多，使用最大 64 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[ret0] = call_table[callee].ret0(reg[arg0], reg[arg1], reg[arg2], reg[arg3], reg[arg4], reg[arg5], reg[arg6], reg[arg7], argc, ret_count, ret0_width) # 运行时通过生成的原生调用桥表写回第 0 个返回槽
    reg[ret1] = call_table[callee].ret1(ret_count, ret1_width) # 若 ret_count 大于 1，运行时写回第 1 个返回槽
    reg[ret2] = call_table[callee].ret2(ret_count, ret2_width) # 若 ret_count 大于 2，运行时写回第 2 个返回槽
    reg[ret3] = call_table[callee].ret3(ret_count, ret3_width) # 若 ret_count 大于 3，运行时写回第 3 个返回槽
    reg[ret4] = call_table[callee].ret4(ret_count, ret4_width) # 若 ret_count 大于 4，运行时写回第 4 个返回槽
    reg[ret5] = call_table[callee].ret5(ret_count, ret5_width) # 若 ret_count 大于 5，运行时写回第 5 个返回槽
    reg[ret6] = call_table[callee].ret6(ret_count, ret6_width) # 若 ret_count 大于 6，运行时写回第 6 个返回槽
    reg[ret7] = call_table[callee].ret7(ret_count, ret7_width) # 若 ret_count 大于 7，运行时写回第 7 个返回槽
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 call_native 指令

instr fake_nop() { # 假指令处理器，用于插入不改变 VM 状态的干扰字节码
