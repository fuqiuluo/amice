rule llvm.icmp.scalar { # 将 LLVM 整数或指针 icmp 降低为 ruoke icmp VM 指令
  match %r = llvm.icmp scalar %a, %b # 匹配整数或指针标量比较谓词
  lower { # 开始声明 icmp 的 lowering 动作
    %va = materialize %a as scalar # 将左比较值按整数或指针 bit 物化为 VM 值
    %vb = materialize %b as scalar # 将右比较值按整数或指针 bit 物化为 VM 值
    %vr = vreg i1 # 为比较结果分配一个布尔 VM x 寄存器
    emit icmp pred=predicate(%r), dst=%vr, lhs=%va, rhs=%vb, width=operand_width(%a,%b) # 发射 profile ISA 中的 icmp 指令
    bind %r = %vr # 记录 LLVM 比较结果到 VM 寄存器的绑定
  } # 结束 icmp lowering 动作
} # 结束 icmp 规则

rule llvm.fcmp.float { # 将 LLVM fcmp 降低为 fcmp VM 指令
  match %r = llvm.fcmp float %a, %b # 匹配 f32 或 f64 标量浮点比较谓词
  lower { # 开始声明 fcmp 的 lowering 动作
