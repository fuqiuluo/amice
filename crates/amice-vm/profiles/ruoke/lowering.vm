    %vb = materialize %b as float # 将右比较值的浮点 bit 物化为 VM 值
    %vr = vreg i1 # 为比较结果分配一个布尔 VM x 寄存器
    emit fcmp pred=predicate(%r), dst=%vr, lhs=%va, rhs=%vb, width=operand_width(%a,%b) # 发射 profile ISA 中的 fcmp 指令
    bind %r = %vr # 记录 LLVM 比较结果到 VM 寄存器的绑定
  } # 结束 fcmp lowering 动作
} # 结束 fcmp 规则

rule llvm.is.fpclass.float { # 将 LLVM is.fpclass 降低为 fpclass VM 指令
  match %r = llvm.is.fpclass float %a, mask # 匹配 f32 或 f64 标量浮点分类 intrinsic
  lower { # 开始声明 fpclass 的 lowering 动作
