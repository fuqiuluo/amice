} # 结束 memset 规则

rule llvm.memset.dynamic { # 将动态长度或过大固定长度 llvm.memset 降低为 ruoke VM memset_dyn
  match llvm.memset dynamic %dst, %value, %len # 匹配长度到运行时才确定，或固定长度超过内联展开上限的 memset intrinsic
  lower { # 开始声明动态 memset lowering 动作
    %vd = materialize %dst as ptr # 将目标地址物化为 VM 指针值
    %vv = materialize %value as integer # 将 i8 填充值物化为 VM 整数值
    %vl = materialize %len as integer # 将运行时长度物化为 VM 整数值
    emit memset_dyn dst=%vd, value=%vv, len=%vl # 发射 ruoke profile 驱动的动态 memset 指令
  } # 结束动态 memset lowering 动作
} # 结束动态 memset 规则

rule llvm.volatile.memset.dynamic { # 将 volatile llvm.memset 归一化为 ruoke VM volatile_memset_dyn
  match llvm.volatile.memset dynamic %dst, %value, %len # 匹配 volatile memset；常量长度也由 translator 物化成运行时长度
  lower { # 开始声明 volatile 动态 memset lowering 动作
    %vd = materialize %dst as ptr # 将 volatile memset 目标地址物化为 VM 指针值
    %vv = materialize %value as integer # 将 i8 填充值物化为 VM 整数值
    %vl = materialize %len as integer # 将写入长度物化为 VM 整数值
    emit volatile_memset_dyn dst=%vd, value=%vv, len=%vl # 发射 ruoke 逐字节 volatile memset 指令
  } # 结束 volatile 动态 memset lowering 动作
} # 结束 volatile 动态 memset 规则

rule llvm.gep.constant { # 将常量偏移 LLVM getelementptr 降低为 VM 指针算术
  match %r = llvm.gep constant %base # 匹配可静态求字节偏移的 GEP
  lower { # 开始声明常量 GEP lowering 动作
    %vb = materialize %base as ptr # 将基址物化为 VM 指针值
    %vr = vreg ptr # 为结果地址分配一个 VM x 寄存器
    emit gep dst=%vr, base=%vb, offset=constant_gep_offset(%r) # 发射 VM 字节偏移指针算术
    bind %r = %vr # 记录 LLVM GEP 结果到 VM 寄存器的绑定
  } # 结束常量 GEP lowering 动作
} # 结束常量 GEP 规则

rule llvm.gep.dynamic { # 将动态 GEP 展开为乘法、加法和最终字节偏移
  match %r = llvm.gep dynamic %base, %index # 匹配包含变量下标以及常量 struct 字段偏移的 GEP
  lower { # 开始声明动态 GEP lowering 动作
    %vb = materialize %base as ptr # 将基址物化为 VM 指针值
    %vi = materialize %index as i64 # 将动态下标物化为 VM 整数值
    %vs = vreg i64 # 为缩放后的下标分配 VM x 寄存器
    %vr = vreg ptr # 为最终地址分配 VM x 寄存器
    emit imul dst=%vs, lhs=%vi, rhs=element_size(%base), width=64 # 变量下标先乘元素字节宽度
    emit iadd dst=%vr, lhs=%vb, rhs=%vs, width=64 # 缩放偏移与基址相加
    emit gep dst=%vr, base=%vr, offset=constant_gep_offset(%r) # 追加可静态求值的字节偏移
    bind %r = %vr # 记录 LLVM GEP 结果到 VM 寄存器的绑定
  } # 结束动态 GEP lowering 动作
} # 结束动态 GEP 规则

rule llvm.call.direct { # 将直接标量整数调用降低为生成的原生调用桥
  match %r = llvm.call direct %callee # 匹配可解析 callee 的直接调用
  lower { # 开始声明直接调用 lowering 动作
    %vr = vreg call_result # 为原生调用返回槽保留 VM x 寄存器
    emit call_native callee=native_id(%callee), argc=arg_count(%callee), arg0=arg0, ret_count=return_count(%callee) # 发射原生调用桥指令
    bind %r = %vr # 记录直接调用结果到 VM 寄存器或聚合绑定
  } # 结束直接调用 lowering 动作
} # 结束直接调用规则

rule llvm.call.indirect { # 将间接标量调用降低为生成的 ruoke 原生调用桥
  match %r = llvm.call indirect %callee # 匹配 callee 来自运行时指针值的间接调用
  lower { # 开始声明间接调用 lowering 动作
    %vr = vreg call_result # 为间接调用返回槽保留 VM x 寄存器
    emit call_native callee=native_id(%callee), argc=arg_count(%callee), arg0=arg0, ret_count=return_count(%callee) # 发射携带 adapter thunk 的 ruoke 原生调用桥指令
    bind %r = %vr # 记录间接调用结果到 VM 寄存器或聚合绑定
  } # 结束间接调用 lowering 动作
} # 结束间接调用规则

rule llvm.select.scalar { # 将 LLVM 标量 select 降低为条件分支和 mov 序列
  match %r = llvm.select scalar %cond, %then, %else # 匹配整数、指针或 f32/f64 标量 select
  lower { # 开始声明 select lowering 动作
    %vc = materialize %cond as i1 # 将条件物化为 VM 布尔值
    %vt = materialize %then as scalar # 将 then 标量 bit 物化为 VM 值
    %ve = materialize %else as scalar # 将 else 标量 bit 物化为 VM 值
    %vr = vreg scalar # 为 select 结果分配 VM x 寄存器
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # 根据条件跳转到 then 或 else 片段
    emit mov dst=%vr, src=%vt, width=type_width(%r) # then 片段复制 then 值
    emit br target=join_label # then 片段跳转到汇合点
    emit mov dst=%vr, src=%ve, width=type_width(%r) # else 片段复制 else 值
    bind %r = %vr # 记录 LLVM select 结果到 VM 寄存器的绑定
  } # 结束 select lowering 动作
} # 结束 select 规则

rule llvm.select.aggregate { # 将 LLVM 聚合 select 拆成逐叶子字段的条件复制
  match %r = llvm.select aggregate %cond, %then, %else # 匹配直接 struct 或固定数组聚合 select
  lower { # 开始声明聚合 select lowering 动作
    %vc = materialize %cond as i1 # 将条件物化为 VM 布尔值
    %vt = materialize %then_field as scalar # 将当前 then 叶子字段物化为 VM 值
    %ve = materialize %else_field as scalar # 将当前 else 叶子字段物化为 VM 值
    %vr = vreg scalar # 为当前结果叶子字段分配 VM x 寄存器
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # 根据条件进入 then 或 else 字段复制片段
    emit mov dst=%vr, src=%vt, width=type_width(%field) # then 片段复制当前叶子字段
    emit br target=join_label # then 片段跳转到聚合 select 汇合点
    emit mov dst=%vr, src=%ve, width=type_width(%field) # else 片段复制当前叶子字段
    bind %r = %vr # 记录当前叶子字段的临时绑定，translator 会组成聚合结果
  } # 结束聚合 select lowering 动作
} # 结束聚合 select 规则

rule llvm.aggregate.insert { # 将 insertvalue 记录为 VM 聚合字段绑定
  match %r = llvm.insertvalue aggregate %agg, %field # 匹配结构体或固定数组的标量叶子字段插入
  lower { # 开始声明 insertvalue lowering 动作
    %vf = materialize %field as integer # 将待插入字段物化为 VM 值
    %vr = vreg aggregate # 为聚合绑定保留一个逻辑 VM 结果
    emit mov dst=%vr, src=%vf, width=type_width(%field) # 字段值必要时通过 mov 稳定绑定
    bind %r = %vr # 记录 LLVM 聚合结果到 VM 聚合绑定
  } # 结束 insertvalue lowering 动作
} # 结束 insertvalue 规则

rule llvm.aggregate.insert.subaggregate { # 将 insertvalue 子聚合展开为逐字段 VM 绑定
  match %r = llvm.insertvalue aggregate %agg, subaggregate %field # 匹配结构体或固定数组的整个子聚合插入
  lower { # 开始声明子聚合 insertvalue lowering 动作
    %vf = materialize %field as scalar # 将当前子聚合叶子字段物化为 VM x 寄存器值
    %vr = vreg scalar # 为复制后的叶子字段分配 VM x 寄存器
    emit mov dst=%vr, src=%vf, width=type_width(%field) # 用 mov 稳定该叶子字段的 bit pattern
    bind %r = %vr # 记录当前叶子字段的临时绑定，translator 会写入聚合字段槽
  } # 结束子聚合 insertvalue lowering 动作
} # 结束子聚合 insertvalue 规则

rule llvm.aggregate.extract { # 将 extractvalue 从 VM 聚合字段绑定中读取
  match %r = llvm.extractvalue aggregate %agg # 匹配结构体或固定数组的标量叶子字段读取
  lower { # 开始声明 extractvalue lowering 动作
    %va = materialize %agg as aggregate # 读取已有聚合绑定
    %vr = vreg integer # 为字段结果分配 VM x 寄存器
    emit mov dst=%vr, src=field(%va), width=type_width(%r) # 将聚合字段复制到结果寄存器
    bind %r = %vr # 记录 LLVM 字段结果到 VM 寄存器的绑定
  } # 结束 extractvalue lowering 动作
} # 结束 extractvalue 规则

rule llvm.aggregate.extract.subaggregate { # 将 extractvalue 子聚合展开为逐字段 VM 绑定
  match %r = llvm.extractvalue subaggregate %agg # 匹配结构体或固定数组的整个子聚合读取
  lower { # 开始声明子聚合 extractvalue lowering 动作
    %vf = materialize %field as scalar # 将当前子聚合叶子字段物化为 VM x 寄存器值
    %vr = vreg scalar # 为读取出的叶子字段分配 VM x 寄存器
    emit mov dst=%vr, src=%vf, width=type_width(%field) # 用 mov 复制该叶子字段
    bind %r = %vr # 记录当前叶子字段的临时绑定，translator 会组成新的聚合结果
  } # 结束子聚合 extractvalue lowering 动作
} # 结束子聚合 extractvalue 规则

rule llvm.br.control { # 将 LLVM 条件和无条件分支终结指令降低为 VM 控制流
  match llvm.br terminator # 匹配 LLVM br 终结指令
  lower { # 开始声明 br lowering 动作
    %vc = materialize %cond as i1 # 条件分支时将条件物化为 VM 布尔值
    emit br target=target_label # 无条件边发射 br 指令
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # 条件边发射 br_if 指令
  } # 结束 br lowering 动作
} # 结束分支规则

rule llvm.switch.control { # 将 LLVM switch 终结指令降低为链式比较和分支
  match llvm.switch terminator # 匹配 LLVM switch 终结指令
  lower { # 开始声明 switch lowering 动作
    %vc = materialize %cond as integer # 将 switch 条件物化为 VM 整数值
    %vk = materialize %case as integer # 将 case 常量物化为 VM 整数值
    %vm = vreg i1 # 为 case 命中结果分配 VM 布尔寄存器
    emit icmp pred=eq, dst=%vm, lhs=%vc, rhs=%vk, width=type_width(%cond) # 每个 case 先发射相等比较
    emit br_if cond=%vm, then_pc=case_label, else_pc=next_case_label # 命中时跳转 case，否则检查下一项
    emit br target=default_label # 未命中任何 case 时跳转默认块
  } # 结束 switch lowering 动作
} # 结束 switch 规则

rule llvm.unreachable { # 将 LLVM unreachable 终结指令降低为 VM 未定义行为终结处理器
  match llvm.unreachable terminator # 匹配 LLVM unreachable terminator
  lower { # 开始声明 unreachable lowering 动作
    emit unreachable # 发射 profile ISA 中的 unreachable 指令
  } # 结束 unreachable lowering 动作
} # 结束 unreachable 规则

rule llvm.trap { # 将 LLVM trap intrinsic 降低为 VM trap 终结处理器
  match llvm.trap intrinsic # 匹配 LLVM trap intrinsic 调用
  lower { # 开始声明 trap lowering 动作
    emit trap # 发射 profile ISA 中的 trap 指令
  } # 结束 trap lowering 动作
} # 结束 trap 规则

rule llvm.ret.scalar { # 将 LLVM 标量整数 return 终结指令降低为 VM 返回
  match llvm.ret scalar %value # 匹配标量或指针返回
  lower { # 开始声明标量返回 lowering 动作
    %vv = materialize %value as integer # 将返回值物化为 VM 值
    emit ret src=%vv # 发射 VM 返回指令
  } # 结束标量返回 lowering 动作
} # 结束标量返回规则

rule llvm.ret.void { # 将 LLVM void return 降低为退出 VM 分派但不读取返回寄存器
  match llvm.ret void # 匹配 void 返回
  lower { # 开始声明 void 返回 lowering 动作
    emit ret src=x0 # 复用 ret 处理器退出分派，wrapper 忽略返回寄存器
  } # 结束 void 返回 lowering 动作
} # 结束 void 返回规则

rule llvm.ret.aggregate { # 将直接结构体返回字段拆分到 ret0..retN ABI 返回槽
  match llvm.ret aggregate %value # 匹配直接聚合返回
  lower { # 开始声明聚合返回 lowering 动作
    %vf = materialize %field as integer # 将每个聚合字段物化为 VM 值
    emit mov dst=ret_slot, src=%vf, width=field_width(%field) # 将字段复制到 ABI 返回槽
    emit ret src=ret0 # 发射 VM 返回指令退出分派
  } # 结束聚合返回 lowering 动作
} # 结束聚合返回规则

rule llvm.ret.sret { # 将 sret 形式的结构体返回写入宿主 ABI 提供的返回指针
  match llvm.ret sret %ptr # 匹配带 sret 返回缓冲区的 void 返回函数
  lower { # 开始声明 sret 返回 lowering 动作
    %vp = materialize %ptr as ptr # 将 sret 返回缓冲区物化为 VM 指针值
    %vf = materialize %field as integer # 将待写回字段物化为 VM 值
    emit store src=%vf, ptr=%vp, width=field_width(%field) # 将聚合字段写回宿主 ABI 返回缓冲区
    emit ret src=x0 # 发射 VM 返回指令退出分派
  } # 结束 sret lowering 动作
} # 结束 sret 返回规则

rule llvm.phi.edge_move { # 将 LLVM phi 规范化为前驱边上的 VM move
  match %r = llvm.phi edge %incoming # 匹配 phi 的前驱边输入
  lower { # 开始声明 phi edge lowering 动作
    %vi = materialize %incoming as integer # 将前驱边输入物化为 VM 值
    %vr = vreg integer # 复用 phi 目标的 VM 寄存器
    emit mov dst=%vr, src=%vi, width=type_width(%r) # 在前驱边发射 mov 物化 phi 结果
    bind %r = %vr # 记录 phi 结果到 VM 寄存器的绑定
  } # 结束 phi edge lowering 动作
} # 结束 phi 规则

rule llvm.aggregate.phi.edge_move { # 将 LLVM 聚合 phi 规范化为前驱边上的逐字段 VM move
  match %r = llvm.phi aggregate edge %incoming # 匹配结构体或固定数组聚合 phi 的前驱边输入
  lower { # 开始声明聚合 phi edge lowering 动作
    %vi = materialize %incoming_field as scalar # 将当前前驱边叶子字段物化为 VM 值
    %vr = vreg scalar # 复用当前 phi 结果叶子字段的 VM 寄存器
    emit mov dst=%vr, src=%vi, width=type_width(%field) # 在前驱边复制当前叶子字段
    bind %r = %vr # 记录当前叶子字段临时绑定，translator 会保持聚合结果绑定
  } # 结束聚合 phi edge lowering 动作
} # 结束聚合 phi 规则
