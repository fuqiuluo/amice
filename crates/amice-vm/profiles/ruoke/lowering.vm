fusion super.iadd_xor { # 声明 iadd 后紧跟 ixor 的超级指令融合模板
  target iadd_xor # 融合后发射 isa.vm 中的 iadd_xor 指令
  sequence iadd, ixor # 只允许把连续的 iadd 与 ixor 两条 VM 指令融合
  require adjacent # 两条源指令必须在线性 VM IR 中相邻
  require no_label_between # 第二条源指令位置不能是任何 VM label 的目标
  require temp_single_use # iadd 产生的临时寄存器只能被紧邻的 ixor 使用
  require same_width # iadd 和 ixor 的整数位宽必须一致
} # 结束 iadd_xor 融合模板

