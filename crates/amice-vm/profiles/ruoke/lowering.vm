    %vc = materialize %c as float # 将加数操作数的浮点 bit 物化为 VM 值
    %vr = vreg float # 为 fma 结果分配一个 VM x 寄存器
    emit ffma dst=%vr, lhs=%va, rhs=%vb, third=%vc, width=type_width(%r) # 发射 ruoke ISA 中的 ffma 指令
    bind %r = %vr # 记录 LLVM 结果到 VM 寄存器的绑定
  } # 结束 fma lowering 动作
} # 结束 fma 规则

