instr mov_imm(dst: vreg<i64>, imm: imm<u64>, width: imm<u8>) { # 将立即数物化到 VM 的 x 寄存器
  opcode alias [0x01, 0x0e, 0x4f, 0x60, 0x65] # mov_imm 使用主操作码 0x01，其余为等价混淆别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(imm, width) # 立即数字段按请求的整数宽度截断或掩码
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 mov_imm 指令

instr const_load(dst: vreg<i64>, index: const_pool_index, width: imm<u8>) { # 从加密常量池按索引物化常量
  opcode alias [0x03, 0x0a, 0x45, 0x5d, 0x5f] # const_load 使用主操作码 0x03，其余为等价混淆别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = const_pool[index] # runtime 先解密常量池，再按 index 读取对应常量
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 const_load 指令

instr mov(dst: vreg<i64>, src: vreg<i64>, width: imm<u8>) { # 将一个 VM x 寄存器复制到另一个寄存器
  opcode alias [0x02, 0x06, 0x3a, 0x56, 0x75] # mov 使用主操作码 0x02，其余为等价混淆别名
  decoded_width = 8 # mov 的 opcode 和三个短操作数固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[src], width) # 源寄存器低位复制到目标寄存器并按 width 掩码
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 mov 指令

instr tls_addr(dst: vreg<i64>, src: vreg<i64>, width: imm<u8>) { # 线程本地地址包装处理器，保留运行时指针值
  opcode alias [0x13b, 0x13c] # tls_addr 使用独立多字节 opcode，避免和普通 mov 混成同一指令身份
  decoded_width = 8 # tls_addr 的 opcode 和三个短操作数固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[src], width) # threadlocal.address 返回同一运行时指针 bit
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 tls_addr 指令

instr global_addr(dst: vreg<i64>, src: vreg<i64>, width: imm<u8>) { # 普通全局符号地址包装处理器，保留重定位后的运行时指针值
  opcode alias [0x13d, 0x13e] # global_addr 使用独立多字节 opcode，让全局地址物化在字节码中可区分
  decoded_width = 8 # global_addr 的 opcode 和三个短操作数固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[src], width) # native thunk 返回的全局地址 bit 复制到 VM x 寄存器
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 global_addr 指令

instr read_cycle(dst: vreg<i64>, width: imm<u8>) { # 读取 LLVM readcyclecounter 计数器并写入 VM x 寄存器
  opcode alias [0x1aa, 0x1ab] # read_cycle 使用独立多字节 opcode，避免和普通原生调用桥混用
  decoded_width = 8 # read_cycle 的 opcode、目标寄存器和位宽固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = read_counter(cycle) # runtime 调用 llvm.readcyclecounter 并取得 i64 计数值
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 read_cycle 指令

instr read_steady(dst: vreg<i64>, width: imm<u8>) { # 读取 LLVM readsteadycounter 计数器并写入 VM x 寄存器
  opcode alias [0x1ac, 0x1ad] # read_steady 使用独立多字节 opcode，和 read_cycle 保持不同 handler 身份
  decoded_width = 8 # read_steady 的 opcode、目标寄存器和位宽固定放入 8 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = read_counter(steady) # runtime 调用 llvm.readsteadycounter 并取得 i64 计数值
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 read_steady 指令

instr sideeffect() { # LLVM sideeffect 处理器，用于保留优化器必须看到的副作用屏障
  opcode alias [0x1ae, 0x1af] # sideeffect 使用独立 opcode，避免退化成 fake_nop 后丢失语义身份
  decoded_width = 4 # sideeffect 没有操作数，使用最小 4 字节 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    side_effect() # runtime 调用 llvm.sideeffect intrinsic，保留可见副作用
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 sideeffect 指令

instr iadd(dst: vreg<i64>, lhs: vreg<i64>, rhs: vreg<i64>, width: imm<u8>) { # 整数加法处理器
  opcode alias [0x10, 0x2c, 0x5a, 0x6d, 0x7a] # iadd 使用主操作码 0x10，其余为等价混淆别名
