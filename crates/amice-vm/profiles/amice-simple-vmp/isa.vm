instr mov_imm(dst: vreg<i64>, imm: imm<u64>, width: imm<u8>) { # 将立即数物化到 VM 的 x 寄存器
  opcode alias [0x01, 0x0e, 0x4f, 0x60, 0x65] # mov_imm 使用主操作码 0x01，其余为等价混淆别名
  semantic { # 处理语义由 AMICE 校验器静态识别
