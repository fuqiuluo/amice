  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[dst] = trunc_width(reg[lhs] + reg[rhs] xor reg[xor_rhs], width) # 先计算 lhs+rhs，再与 xor_rhs 做异或并按 width 掩码
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 iadd_xor 超级指令

