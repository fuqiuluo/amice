} # 结束 call_native 指令

instr fake_nop() { # 假指令处理器，用于插入不改变 VM 状态的干扰字节码
  opcode alias [0x39, 0x07, 0x48, 0x64] # fake_nop 使用主操作码 0x39，其余为等价混淆别名
  decoded_width = 4 # fake_nop 只有 opcode，使用最小 4 字节 record
  semantic { # 处理语义由 AMICE 校验器静态识别
    state = unchanged # 该指令不读取或写入任何 VM 数据寄存器
    pc = next # 执行继续到下一条字节码指令
  } # 结束语义块
} # 结束 fake_nop 指令

instr br(target: label) { # 无条件分支处理器
  opcode alias [0x40, 0x1c, 0x4c, 0x67] # br 使用主操作码 0x40，其余为等价混淆别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    pc = target # 执行跳转到目标字节码标签
  } # 结束语义块
} # 结束 br 指令

instr br_if(cond: vreg<i1>, then_pc: label, else_pc: label) { # 条件分支处理器
  opcode alias [0x41, 0x3b, 0x3f, 0x62] # br_if 使用主操作码 0x41，其余为等价混淆别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    pc = select(reg[cond], then_pc, else_pc) # 条件寄存器选择下一条字节码标签
  } # 结束语义块
} # 结束 br_if 指令

instr vm_call(target: label) { # VM 内部调用处理器
  opcode alias [0x42, 0x6e, 0x70, 0x71] # vm_call 使用主操作码 0x42，其余为等价混淆别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[lr] = next # 调用前把返回字节码 PC 写入 runtime.vm 定义的 lr 别名
    pc = target # 执行跳转到目标字节码标签
  } # 结束语义块
} # 结束 vm_call 指令

instr vm_ret() { # VM 内部返回处理器
  opcode alias [0x43, 0x19, 0x29, 0x44] # vm_ret 使用主操作码 0x43，其余为等价混淆别名
  semantic { # 处理语义由 AMICE 校验器静态识别
    pc = reg[lr] # 从 lr 恢复调用点之后的字节码 PC
  } # 结束语义块
} # 结束 vm_ret 指令

instr unreachable() { # LLVM unreachable 终结处理器
  opcode alias [0xdd, 0xde] # unreachable 使用当前 simple profile 空闲操作码，避免和已有别名冲突
  decoded_width = 4 # 无操作数指令仍占用最小 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    unreachable # 执行到这里时生成 LLVM unreachable，保留源 IR 的未定义行为路径
  } # 结束语义块
} # 结束 unreachable 指令

instr trap() { # LLVM trap intrinsic 终结处理器
  opcode alias [0xdf] # trap 使用独立空闲操作码，避免和 unreachable 的未定义行为语义混淆
  decoded_width = 4 # 无操作数 trap 指令仍占用最小 decoded record
  semantic { # 处理语义由 AMICE 校验器静态识别
    trap # 执行到这里时 runtime 调用 LLVM trap intrinsic 并终止控制流
  } # 结束语义块
} # 结束 trap 指令

instr ret(src: vreg<i64>) { # 函数返回处理器
  opcode alias [0x7f, 0x0c, 0x1a, 0x59] # ret 使用主操作码 0x7f，其余为等价混淆别名
  decoded_width = 4 # ret 只需要 opcode 和一个寄存器操作数，使用 4 字节 record
  semantic { # 处理语义由 AMICE 校验器静态识别
    reg[ret0] = reg[src] # 返回值归一化写入 abi.vm 声明的第 0 个返回槽
    pc = return # 分派循环在该指令后退出
  } # 结束语义块
} # 结束 ret 指令
