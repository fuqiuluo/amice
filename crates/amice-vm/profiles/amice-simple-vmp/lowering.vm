rule llvm.vector.step { # 将 fixed integer vector stepvector 展开为每个 lane 的常量编号
  match %r = llvm.stepvector integer # 匹配 LLVM stepvector，结果必须是 fixed integer vector，lane 可为 i8/i16/i32/i64
  lower { # 开始声明 fixed vector stepvector lowering 动作
    %vr = vreg integer # 为当前 lane 的 step 值分配 VM x 寄存器
    emit mov_imm dst=%vr, imm=lane_index(%lane), width=lane_width(%lane) # 将当前 lane 编号按 lane 宽度截断后写入 VM 寄存器
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会组成 fixed vector 结果
  } # 结束 fixed vector stepvector lowering 动作
} # 结束 fixed vector stepvector 规则

rule llvm.vector.get.active.lane.mask { # 将 fixed vector get.active.lane.mask 展开为逐 lane 活跃范围判断
  match %r = llvm.get.active.lane.mask integer %start, %end # 匹配 LLVM get.active.lane.mask，返回值必须是 fixed <N x i1>
  lower { # 开始声明 fixed vector active lane mask lowering 动作
    %vs = materialize %start as integer # 将起始 lane 序号物化为 VM 整数值
    %ve = materialize %end as integer # 将结束 lane 序号物化为 VM 整数值
    %vl = vreg integer # 为当前 lane 的常量编号分配 VM x 寄存器
    %vi = vreg integer # 为 start + lane 的运行时索引分配 VM x 寄存器
    %vr = vreg i1 # 为当前 lane 是否活跃分配 VM 布尔寄存器
    emit mov_imm dst=%vl, imm=lane(%r), width=operand_width(%a,%b) # 将当前 lane 编号按 start/end 宽度写入 VM 寄存器
    emit iadd dst=%vi, lhs=%vs, rhs=%vl, width=operand_width(%a,%b) # 计算当前 lane 对应的绝对迭代位置
    emit icmp pred=ult, dst=%vr, lhs=%vi, rhs=%ve, width=operand_width(%a,%b) # 用无符号小于判断当前 lane 是否仍在有效范围内
    bind %r = %vr # 记录当前 lane 的 i1 结果，translator 会重新组成 fixed mask 向量
  } # 结束 fixed vector active lane mask lowering 动作
} # 结束 fixed vector active lane mask 规则

rule llvm.experimental.get.vector.length.integer { # 将非 scalable get.vector.length 降低为 min(AVL, VF)
  match %r = llvm.experimental.get.vector.length integer %avl, imm %vf, scalable false # 匹配 isScalable=false 的 LLVM vector length 查询，AVL 可为 i1/i8/i16/i32/i64
  lower { # 开始声明 get.vector.length lowering 动作
    %va = materialize %avl as integer # 将运行时剩余元素数 AVL 物化为 VM 整数值
    %vwide = vreg integer # 为窄 AVL 扩宽到比较宽度保留 VM x 寄存器
    %vv = vreg integer # 为固定向量因子 VF 分配与比较宽度同宽的 VM x 寄存器
    %vc = vreg i1 # 为 AVL < VF 的比较结果分配 VM i1 寄存器
    %vt = vreg integer # 为截断到 i32 的 AVL 候选结果分配 VM x 寄存器
    %ve = vreg integer # 为截断到 i32 的 VF 候选结果分配 VM x 寄存器
    %vr = vreg integer # 为最终 i32 vector length 结果分配 VM x 寄存器
    emit zext dst=%vwide, src=%va, from_width=type_width(%avl), to_width=compare_width(%avl) # AVL 窄于 i32 时先零扩展到 i32 比较宽度
    emit mov_imm dst=%vv, imm=vector_factor(%r), width=compare_width(%avl) # 按比较宽度物化固定 VF 常量
    emit icmp pred=ult, dst=%vc, lhs=%vwide, rhs=%vv, width=compare_width(%avl) # 判断 AVL 是否小于固定 VF
    emit trunc dst=%vt, src=%vwide, from_width=compare_width(%avl), to_width=type_width(%r) # 将 AVL 候选值截断到 i32 返回宽度
    emit trunc dst=%ve, src=%vv, from_width=compare_width(%avl), to_width=type_width(%r) # 将 VF 候选值截断到 i32 返回宽度
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # AVL < VF 时选择 AVL，否则选择 VF
    emit mov dst=%vr, src=%vt, width=type_width(%r) # then 分支写入 AVL 候选结果
    emit br target=join_label # then 分支结束后跳到汇合点
    emit mov dst=%vr, src=%ve, width=type_width(%r) # else 分支写入 VF 候选结果
    bind %r = %vr # 记录最终 i32 vector length 到 VM 寄存器绑定
  } # 结束 get.vector.length lowering 动作
} # 结束 get.vector.length 规则

rule llvm.experimental.cttz.elts { # 将 fixed mask 的 cttz.elts 展开为逐 lane 条件覆盖
  match %r = llvm.experimental.cttz.elts vector %mask, zero_is_poison any # 匹配 zero_is_poison=false/true 的 fixed <N x i1> mask 计数 intrinsic；全零 poison 情况选择 lane 总数作为确定代表值
  lower { # 开始声明 cttz.elts lowering 动作
    %vm = materialize %mask_lane as integer # 将当前 mask lane 物化为 VM i1 条件值
    %vk = vreg integer # 为当前候选 lane 编号分配 VM x 寄存器
    %vr = vreg integer # 为 trailing zero element 数量分配 VM x 寄存器
    emit mov_imm dst=%vr, imm=lane_count(%mask), width=type_width(%r) # 默认结果是 mask lane 总数，表示没有任何 active lane
    emit mov_imm dst=%vk, imm=lane(%r), width=type_width(%r) # 物化当前 lane 编号作为候选结果
    emit br_if cond=%vm, then_pc=case_label, else_pc=join_label # 当前 mask lane 为 true 时进入覆盖结果分支
    emit mov dst=%vr, src=%vk, width=type_width(%r) # 将结果覆盖为当前 lane 编号
    emit br target=join_label # 覆盖完成后跳到当前 lane 汇合点
    bind %r = %vr # 记录最终标量计数结果到 VM 寄存器绑定
  } # 结束 cttz.elts lowering 动作
} # 结束 cttz.elts 规则

rule llvm.vp.cttz.elts { # 将 VP fixed mask 的 cttz.elts 展开为逐激活 lane 条件覆盖
  match %r = llvm.vp.cttz.elts vector %mask, zero_is_poison any, const_mask %vp_mask, %evl # 匹配 zero_is_poison=false/true、常量 VP mask 和常量 EVL 的 fixed <N x i1> 计数 intrinsic；全零 poison 情况选择激活 lane 数作为确定代表值
  lower { # 开始声明 VP cttz.elts lowering 动作
    %vm = materialize %mask_lane as integer # 将当前 VP 激活的计数 mask lane 物化为 VM i1 条件值
    %vk = vreg integer # 为当前候选 lane 编号分配 VM x 寄存器
    %vr = vreg integer # 为 VP trailing zero element 数量分配 VM x 寄存器
    emit mov_imm dst=%vr, imm=active_lane_count(%mask,%evl), width=type_width(%r) # 默认结果是 min(EVL, lane_count)，表示激活范围内没有 true lane
    emit mov_imm dst=%vk, imm=lane(%r), width=type_width(%r) # 物化当前激活 lane 编号作为候选结果
    emit br_if cond=%vm, then_pc=case_label, else_pc=join_label # 当前计数 mask lane 为 true 时进入覆盖结果分支
    emit mov dst=%vr, src=%vk, width=type_width(%r) # 将结果覆盖为当前激活 lane 编号
    emit br target=join_label # 覆盖完成后跳到当前 lane 汇合点
    bind %r = %vr # 记录最终标量计数结果到 VM 寄存器绑定
  } # 结束 VP cttz.elts lowering 动作
} # 结束 VP cttz.elts 规则

rule llvm.vector.reduce.add.integer { # 将固定整数向量 reduce.add 拆成多次 iadd 折叠
  match %r = llvm.vector.reduce.add integer %value # 匹配 fixed vector 整数加法归约 intrinsic
