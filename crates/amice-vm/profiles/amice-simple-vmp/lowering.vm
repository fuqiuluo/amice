    %vs = materialize object_size(%ptr) as integer # 将静态对象总字节数物化为 VM 整数值
    %vo = materialize object_offset(%ptr) as integer # 取出 GEP 相对静态对象基址的运行时字节偏移
    %vr = vreg integer # 为剩余 objectsize 结果分配一个 VM x 寄存器
