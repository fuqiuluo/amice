    emit volatile_atomic_rmw_uinc_wrap dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 无符号加一回绕路径发射携带 syncscope 的 volatile_atomic_rmw_uinc_wrap 指令
    emit volatile_atomic_rmw_udec_wrap dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 无符号减一回绕路径发射携带 syncscope 的 volatile_atomic_rmw_udec_wrap 指令
    emit volatile_atomic_rmw_usub_cond dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 条件无符号减法路径发射携带 syncscope 的 volatile_atomic_rmw_usub_cond 指令
    emit volatile_atomic_rmw_usub_sat dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 无符号饱和减法路径发射携带 syncscope 的 volatile_atomic_rmw_usub_sat 指令
    emit volatile_atomic_rmw_fadd dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 浮点加法路径发射携带 syncscope 的 volatile_atomic_rmw_fadd 指令，src 是 IEEE 原始 bit
    emit volatile_atomic_rmw_fsub dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 浮点减法路径发射携带 syncscope 的 volatile_atomic_rmw_fsub 指令，src 是 IEEE 原始 bit
    emit volatile_atomic_rmw_fmax dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 浮点最大值路径发射携带 syncscope 的 volatile_atomic_rmw_fmax 指令
    emit volatile_atomic_rmw_fmin dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 浮点最小值路径发射携带 syncscope 的 volatile_atomic_rmw_fmin 指令
    emit volatile_atomic_rmw_fmaximum dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # IEEE maximum 路径发射携带 syncscope 的 volatile_atomic_rmw_fmaximum 指令
    emit volatile_atomic_rmw_fminimum dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # IEEE minimum 路径发射携带 syncscope 的 volatile_atomic_rmw_fminimum 指令
    bind %r = %vr # 记录 LLVM volatile atomicrmw 返回旧值到 VM 寄存器的绑定
  } # 结束 volatile atomicrmw lowering 动作
} # 结束 volatile atomicrmw 规则

rule llvm.cmpxchg.scalar { # 将标量 cmpxchg 降低为 VM compare-exchange 指令
  match llvm.cmpxchg scalar %ptr, %cmp, %new # 匹配已由 translator 校验过 ordering、类型和自然对齐的 cmpxchg；weak 会按 strong 形式发射
  lower { # 开始声明 cmpxchg lowering 动作
    %vp = materialize %ptr as ptr # 将 compare-exchange 地址物化为 VM 指针值
    %vc = vreg integer # 为期望旧值声明 VM x 寄存器，translator 会绑定真实 compare operand
    %vn = vreg integer # 为成功写入值声明 VM x 寄存器，translator 会绑定真实 new operand
    %old = vreg integer # 为 cmpxchg 返回的内存旧值分配 VM x 寄存器
    %ok = vreg i1 # 为 cmpxchg 成功标志分配 VM 布尔寄存器
    emit cmpxchg old=%old, success=%ok, ptr=%vp, cmp=%vc, new=%vn, width=memory_width(%ptr), success_ordering=success_ordering(%ptr), failure_ordering=failure_ordering(%ptr), sync_scope=sync_scope(%ptr) # 发射携带两个 ordering 和 syncscope 的 cmpxchg 指令
  } # 结束 cmpxchg lowering 动作
} # 结束 cmpxchg 规则

rule llvm.volatile.cmpxchg.scalar { # 将标量 volatile cmpxchg 降低为 VM volatile compare-exchange 指令
  match llvm.volatile.cmpxchg scalar %ptr, %cmp, %new # 匹配已由 translator 校验过 ordering、类型和自然对齐的 volatile cmpxchg
  lower { # 开始声明 volatile cmpxchg lowering 动作
    %vp = materialize %ptr as ptr # 将 volatile compare-exchange 地址物化为 VM 指针值
    %vc = vreg integer # 为期望旧值声明 VM x 寄存器，translator 会绑定真实 compare operand
    %vn = vreg integer # 为成功写入值声明 VM x 寄存器，translator 会绑定真实 new operand
    %old = vreg integer # 为 volatile cmpxchg 返回的内存旧值分配 VM x 寄存器
    %ok = vreg i1 # 为 volatile cmpxchg 成功标志分配 VM 布尔寄存器
    emit volatile_cmpxchg old=%old, success=%ok, ptr=%vp, cmp=%vc, new=%vn, width=memory_width(%ptr), success_ordering=success_ordering(%ptr), failure_ordering=failure_ordering(%ptr), sync_scope=sync_scope(%ptr) # 发射带 volatile 语义、两个 ordering 和 syncscope 的 cmpxchg 指令
  } # 结束 volatile cmpxchg lowering 动作
} # 结束 volatile cmpxchg 规则

rule llvm.fence { # 将默认 system 或 singlethread syncscope 的 LLVM fence 降低为 VM fence 指令
  match llvm.fence ordering sync_scope # 匹配已由 translator 校验过 ordering 和 syncscope 的 fence
  lower { # 开始声明 fence lowering 动作
    emit fence ordering=memory_ordering(%fence), sync_scope=sync_scope(%fence) # 发射携带 ordering 和 syncscope 的 fence 指令
  } # 结束 fence lowering 动作
} # 结束 fence 规则

rule llvm.memcpy.fixed { # 将固定长度 llvm.memcpy 展开为 VM 标量 load/store
  match llvm.memcpy fixed %dst, %src, %len # 匹配长度可静态确定的 memcpy intrinsic
  lower { # 开始声明 memcpy 展开动作
    %vd = materialize %dst as ptr # 将目标地址物化为 VM 指针值
    %vs = materialize %src as ptr # 将源地址物化为 VM 指针值
    %addr = vreg ptr # 为带偏移的临时地址保留 VM x 寄存器
    %tmp = vreg integer # 为每个复制分块保留临时数据寄存器
    emit load dst=%tmp, ptr=%vs, width=copy_width # 偏移为 0 时直接从源基址读取分块
    emit gep dst=%addr, base=%vs, offset=copy_offset # 非零偏移时计算源分块地址
    emit load dst=%tmp, ptr=%addr, width=copy_width # 从源分块地址读取数据
    emit store src=%tmp, ptr=%vd, width=copy_width # 偏移为 0 时直接写入目标基址
    emit gep dst=%addr, base=%vd, offset=copy_offset # 非零偏移时计算目标分块地址
    emit store src=%tmp, ptr=%addr, width=copy_width # 将分块数据写入目标分块地址
  } # 结束 memcpy 展开动作
} # 结束 memcpy 规则

rule llvm.memmove.fixed { # 将固定长度 llvm.memmove 展开为先读后写的 VM 标量复制
  match llvm.memmove fixed %dst, %src, %len # 匹配长度可静态确定的 memmove intrinsic
  lower { # 开始声明 memmove 展开动作
    %vd = materialize %dst as ptr # 将目标地址物化为 VM 指针值
    %vs = materialize %src as ptr # 将源地址物化为 VM 指针值
    %addr = vreg ptr # 为带偏移的临时地址保留 VM x 寄存器
    %tmp = vreg integer # 为每个复制分块保留临时数据寄存器
    emit load dst=%tmp, ptr=%vs, width=copy_width # 偏移为 0 时直接从源基址读取分块
    emit gep dst=%addr, base=%vs, offset=copy_offset # 非零偏移时计算源分块地址
    emit load dst=%tmp, ptr=%addr, width=copy_width # 从源分块地址读取数据
    emit store src=%tmp, ptr=%vd, width=copy_width # 所有源分块读取完成后写入目标基址
    emit gep dst=%addr, base=%vd, offset=copy_offset # 非零偏移时计算目标分块地址
    emit store src=%tmp, ptr=%addr, width=copy_width # 所有源分块读取完成后写入目标分块地址
  } # 结束 memmove 展开动作
} # 结束 memmove 规则

rule llvm.memcpy.dynamic { # 将动态长度或过大固定长度 llvm.memcpy 降低为 VM memcpy_dyn
  match llvm.memcpy dynamic %dst, %src, %len # 匹配长度到运行时才确定，或固定长度超过内联展开上限的 memcpy intrinsic
  lower { # 开始声明动态 memcpy lowering 动作
    %vd = materialize %dst as ptr # 将目标地址物化为 VM 指针值
    %vs = materialize %src as ptr # 将源地址物化为 VM 指针值
    %vl = materialize %len as integer # 将运行时长度物化为 VM 整数值
    emit memcpy_dyn dst=%vd, src=%vs, len=%vl # 发射 profile 驱动的动态 memcpy 指令
  } # 结束动态 memcpy lowering 动作
} # 结束动态 memcpy 规则

rule llvm.memmove.dynamic { # 将动态长度或过大固定长度 llvm.memmove 降低为 VM memmove_dyn
  match llvm.memmove dynamic %dst, %src, %len # 匹配长度到运行时才确定，或固定长度超过内联展开上限且可能重叠的 memmove intrinsic
  lower { # 开始声明动态 memmove lowering 动作
    %vd = materialize %dst as ptr # 将目标地址物化为 VM 指针值
    %vs = materialize %src as ptr # 将源地址物化为 VM 指针值
    %vl = materialize %len as integer # 将运行时长度物化为 VM 整数值
    emit memmove_dyn dst=%vd, src=%vs, len=%vl # 发射 profile 驱动的动态 memmove 指令
  } # 结束动态 memmove lowering 动作
} # 结束动态 memmove 规则

rule llvm.volatile.memcpy.dynamic { # 将 volatile llvm.memcpy 归一化为逐字节 VM volatile_memcpy_dyn
  match llvm.volatile.memcpy dynamic %dst, %src, %len # 匹配 volatile memcpy；常量长度也由 translator 物化成运行时长度
  lower { # 开始声明 volatile 动态 memcpy lowering 动作
    %vd = materialize %dst as ptr # 将 volatile memcpy 目标地址物化为 VM 指针值
    %vs = materialize %src as ptr # 将 volatile memcpy 源地址物化为 VM 指针值
    %vl = materialize %len as integer # 将复制长度物化为 VM 整数值
    emit volatile_memcpy_dyn dst=%vd, src=%vs, len=%vl # 发射逐字节 volatile load/store 的动态 memcpy 指令
  } # 结束 volatile 动态 memcpy lowering 动作
} # 结束 volatile 动态 memcpy 规则

rule llvm.volatile.memmove.dynamic { # 将 volatile llvm.memmove 归一化为逐字节 VM volatile_memmove_dyn
  match llvm.volatile.memmove dynamic %dst, %src, %len # 匹配 volatile memmove；运行时根据地址方向处理重叠区域
  lower { # 开始声明 volatile 动态 memmove lowering 动作
    %vd = materialize %dst as ptr # 将 volatile memmove 目标地址物化为 VM 指针值
    %vs = materialize %src as ptr # 将 volatile memmove 源地址物化为 VM 指针值
    %vl = materialize %len as integer # 将复制长度物化为 VM 整数值
    emit volatile_memmove_dyn dst=%vd, src=%vs, len=%vl # 发射保留 volatile 访存标记的动态 memmove 指令
  } # 结束 volatile 动态 memmove lowering 动作
} # 结束 volatile 动态 memmove 规则

rule llvm.memset.fixed { # 将固定长度 llvm.memset 展开为 VM 字节 store
  match llvm.memset fixed %dst, %value, %len # 匹配长度可静态确定的 memset intrinsic
  lower { # 开始声明 memset 展开动作
    %vd = materialize %dst as ptr # 将目标地址物化为 VM 指针值
    %vv = materialize %value as integer # 将 i8 填充值物化为 VM 整数值
    %addr = vreg ptr # 为带偏移的目标地址保留 VM x 寄存器
    emit store src=%vv, ptr=%vd, width=set_width # 偏移为 0 时直接写入目标基址字节
    emit gep dst=%addr, base=%vd, offset=set_offset # 非零偏移时计算目标字节地址
    emit store src=%vv, ptr=%addr, width=set_width # 将填充值写入目标偏移字节
  } # 结束 memset 展开动作
} # 结束 memset 规则

rule llvm.memset.dynamic { # 将动态长度或过大固定长度 llvm.memset 降低为 VM memset_dyn
  match llvm.memset dynamic %dst, %value, %len # 匹配长度到运行时才确定，或固定长度超过内联展开上限的 memset intrinsic
  lower { # 开始声明动态 memset lowering 动作
    %vd = materialize %dst as ptr # 将目标地址物化为 VM 指针值
    %vv = materialize %value as integer # 将 i8 填充值物化为 VM 整数值
    %vl = materialize %len as integer # 将运行时长度物化为 VM 整数值
    emit memset_dyn dst=%vd, value=%vv, len=%vl # 发射 profile 驱动的动态 memset 指令
  } # 结束动态 memset lowering 动作
} # 结束动态 memset 规则

rule llvm.volatile.memset.dynamic { # 将 volatile llvm.memset 归一化为逐字节 VM volatile_memset_dyn
  match llvm.volatile.memset dynamic %dst, %value, %len # 匹配 volatile memset；常量长度也由 translator 物化成运行时长度
  lower { # 开始声明 volatile 动态 memset lowering 动作
    %vd = materialize %dst as ptr # 将 volatile memset 目标地址物化为 VM 指针值
    %vv = materialize %value as integer # 将 i8 填充值物化为 VM 整数值
    %vl = materialize %len as integer # 将写入长度物化为 VM 整数值
    emit volatile_memset_dyn dst=%vd, value=%vv, len=%vl # 发射逐字节 volatile store 的动态 memset 指令
  } # 结束 volatile 动态 memset lowering 动作
} # 结束 volatile 动态 memset 规则

rule llvm.gep.constant { # 将常量偏移 LLVM getelementptr 降低为 VM 指针算术
  match %r = llvm.gep constant %base # 匹配可静态求字节偏移的 GEP
  lower { # 开始声明常量 GEP lowering 动作
    %vb = materialize %base as ptr # 将基址物化为 VM 指针值
    %vr = vreg ptr # 为结果地址分配一个 VM x 寄存器
    emit gep dst=%vr, base=%vb, offset=constant_gep_offset(%r) # 发射 VM 字节偏移指针算术
    bind %r = %vr # 记录 LLVM GEP 结果到 VM 寄存器的绑定
  } # 结束常量 GEP lowering 动作
} # 结束常量 GEP 规则

rule llvm.gep.dynamic { # 将动态 GEP 展开为乘法、加法和最终字节偏移
  match %r = llvm.gep dynamic %base, %index # 匹配包含变量下标以及常量 struct 字段偏移的 GEP
  lower { # 开始声明动态 GEP lowering 动作
    %vb = materialize %base as ptr # 将基址物化为 VM 指针值
    %vi = materialize %index as integer # 将动态下标按 LLVM 原始整数位宽物化
    %vx = vreg i64 # 为按 GEP 有符号索引语义扩展到指针宽度后的下标分配寄存器
    %vs = vreg i64 # 为缩放后的下标分配 VM x 寄存器
    %vr = vreg ptr # 为最终地址分配 VM x 寄存器
    emit sext dst=%vx, src=%vi, from_width=type_width(%index), to_width=64 # 窄整数下标先按 LLVM GEP 规则符号扩展到 64 位
    emit imul dst=%vs, lhs=%vx, rhs=element_size(%base), width=64 # 扩展后的变量下标乘元素字节宽度
    emit iadd dst=%vr, lhs=%vb, rhs=%vs, width=64 # 缩放偏移与基址相加
    emit gep dst=%vr, base=%vr, offset=constant_gep_offset(%r) # 追加可静态求值的字节偏移
    bind %r = %vr # 记录 LLVM GEP 结果到 VM 寄存器的绑定
  } # 结束动态 GEP lowering 动作
} # 结束动态 GEP 规则

rule llvm.call.direct { # 将直接标量整数调用降低为生成的原生调用桥
  match %r = llvm.call direct %callee # 匹配可解析 callee 的直接调用
  lower { # 开始声明直接调用 lowering 动作
    %vr = vreg call_result # 为原生调用返回槽保留 VM x 寄存器
    emit call_native callee=native_id(%callee), argc=arg_count(%callee), arg0=arg0, ret_count=return_count(%callee) # 发射原生调用桥指令
    bind %r = %vr # 记录直接调用结果到 VM 寄存器或聚合绑定
  } # 结束直接调用 lowering 动作
} # 结束直接调用规则

rule llvm.call.indirect { # 将间接标量调用降低为生成的原生调用桥
  match %r = llvm.call indirect %callee # 匹配 callee 来自运行时指针值的间接调用
  lower { # 开始声明间接调用 lowering 动作
    %vr = vreg call_result # 为间接调用返回槽保留 VM x 寄存器
    emit call_native callee=native_id(%callee), argc=arg_count(%callee), arg0=arg0, ret_count=return_count(%callee) # 发射携带 adapter thunk 的原生调用桥指令
    bind %r = %vr # 记录间接调用结果到 VM 寄存器或聚合绑定
  } # 结束间接调用 lowering 动作
} # 结束间接调用规则

rule llvm.select.scalar { # 将 LLVM 标量 select 降低为条件分支和 mov 序列
  match %r = llvm.select scalar %cond, %then, %else # 匹配整数、指针或 f16/f32/f64 标量 select
  lower { # 开始声明 select lowering 动作
    %vc = materialize %cond as i1 # 将条件物化为 VM 布尔值
    %vt = materialize %then as scalar # 将 then 标量 bit 物化为 VM 值
    %ve = materialize %else as scalar # 将 else 标量 bit 物化为 VM 值
    %vr = vreg scalar # 为 select 结果分配 VM x 寄存器
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # 根据条件跳转到 then 或 else 片段
    emit mov dst=%vr, src=%vt, width=type_width(%r) # then 片段复制 then 值
    emit br target=join_label # then 片段跳转到汇合点
    emit mov dst=%vr, src=%ve, width=type_width(%r) # else 片段复制 else 值
    bind %r = %vr # 记录 LLVM select 结果到 VM 寄存器的绑定
  } # 结束 select lowering 动作
} # 结束 select 规则

rule llvm.select.aggregate { # 将 LLVM 聚合 select 拆成逐叶子字段的条件复制
  match %r = llvm.select aggregate %cond, %then, %else # 匹配直接 struct 或固定数组聚合 select
  lower { # 开始声明聚合 select lowering 动作
    %vc = materialize %cond as i1 # 将条件物化为 VM 布尔值
    %vt = materialize %then_field as scalar # 将当前 then 叶子字段物化为 VM 值
    %ve = materialize %else_field as scalar # 将当前 else 叶子字段物化为 VM 值
    %vr = vreg scalar # 为当前结果叶子字段分配 VM x 寄存器
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # 根据条件进入 then 或 else 字段复制片段
    emit mov dst=%vr, src=%vt, width=type_width(%field) # then 片段复制当前叶子字段
    emit br target=join_label # then 片段跳转到聚合 select 汇合点
    emit mov dst=%vr, src=%ve, width=type_width(%field) # else 片段复制当前叶子字段
    bind %r = %vr # 记录当前叶子字段的临时绑定，translator 会组成聚合结果
  } # 结束聚合 select lowering 动作
} # 结束聚合 select 规则

rule llvm.select.vector { # 将固定向量 select 拆成逐 lane 的条件复制
  match %r = llvm.select vector %cond, %then, %else # 匹配 scalar i1 条件选择固定向量值
  lower { # 开始声明固定向量 select lowering 动作
    %vc = materialize %cond as i1 # 将条件物化为 VM 布尔值
    %vt = materialize %then_lane as scalar # 将当前 then lane 物化为 VM 值
    %ve = materialize %else_lane as scalar # 将当前 else lane 物化为 VM 值
    %vr = vreg scalar # 为当前结果 lane 分配 VM x 寄存器
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # 根据条件进入 then 或 else lane 复制片段
    emit mov dst=%vr, src=%vt, width=type_width(%field) # then 片段复制当前 lane
    emit br target=join_label # then 片段跳转到固定向量 select 汇合点
    emit mov dst=%vr, src=%ve, width=type_width(%field) # else 片段复制当前 lane
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会组成固定向量结果
  } # 结束固定向量 select lowering 动作
} # 结束固定向量 select 规则

rule llvm.select.vector_condition { # 将固定向量条件 select 拆成逐 lane 条件复制
  match %r = llvm.select vector_condition %cond, %then, %else # 匹配 <N x i1> 条件选择固定向量值
  lower { # 开始声明固定向量条件 select lowering 动作
    %vc = materialize %cond_lane as i1 # 将当前条件 lane 物化为 VM 布尔值
    %vt = materialize %then_lane as scalar # 将当前 then lane 物化为 VM 值
    %ve = materialize %else_lane as scalar # 将当前 else lane 物化为 VM 值
    %vr = vreg scalar # 为当前结果 lane 分配 VM x 寄存器
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # 根据当前条件 lane 进入 then 或 else 片段
    emit mov dst=%vr, src=%vt, width=type_width(%field) # then 片段复制当前 lane
    emit br target=join_label # then 片段跳转到当前 lane 汇合点
    emit mov dst=%vr, src=%ve, width=type_width(%field) # else 片段复制当前 lane
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会组成固定向量结果
  } # 结束固定向量条件 select lowering 动作
} # 结束固定向量条件 select 规则

rule llvm.vp.select.vector_condition { # 将 VP 固定向量 select 的激活 lane 拆成逐 lane 条件复制
  match %r = llvm.vp.select vector_condition %cond, %then, %else, %evl # 匹配常量 EVL 的 fixed vector VP select
  lower { # 开始声明 VP 固定向量 select lowering 动作
    %vc = materialize %cond_lane as i1 # 将当前激活条件 lane 物化为 VM 布尔值
    %vt = materialize %then_lane as scalar # 将当前激活 then lane 物化为 VM 值
    %ve = materialize %else_lane as scalar # 将当前激活 else lane 物化为 VM 值
    %vr = vreg scalar # 为当前激活结果 lane 分配 VM x 寄存器
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # 根据当前激活条件 lane 进入 then 或 else 片段
    emit mov dst=%vr, src=%vt, width=type_width(%field) # then 片段复制当前激活 lane
    emit br target=join_label # then 片段跳转到当前激活 lane 汇合点
    emit mov dst=%vr, src=%ve, width=type_width(%field) # else 片段复制当前激活 lane
    bind %r = %vr # 记录当前激活 lane 临时绑定，未激活 lane 由 translator 保留为 poison
  } # 结束 VP 固定向量 select lowering 动作
} # 结束 VP 固定向量 select 规则

rule llvm.vp.merge.vector_condition { # 将 VP 固定向量 merge 拆成带 pivot 检查的逐 lane 条件复制
  match %r = llvm.vp.merge vector_condition %cond, %then, %else, %pivot # 匹配 fixed vector VP merge，pivot 可以是运行时整数
  lower { # 开始声明 VP 固定向量 merge lowering 动作
    %vc = materialize %cond_lane as i1 # 将当前条件 lane 物化为 VM 布尔值
    %vt = materialize %then_lane as scalar # 将当前 then lane 物化为 VM 值
    %ve = materialize %else_lane as scalar # 将当前 else lane 物化为 VM 值
    %vp = materialize %pivot as integer # 将运行时 pivot 物化为 VM 整数，表示 then 分支允许的最大 lane 边界
    %vk = vreg integer # 为当前 lane 编号分配 VM 临时寄存器
    %vm = vreg i1 # 为 lane < pivot 的比较结果分配 VM 布尔寄存器
    %vr = vreg scalar # 为当前结果 lane 分配 VM x 寄存器
    emit mov_imm dst=%vk, imm=lane(%r), width=type_width(%pivot) # 将当前 lane 编号写入与 pivot 同宽的整数寄存器
    emit icmp pred=ult, dst=%vm, lhs=%vk, rhs=%vp, width=type_width(%pivot) # 判断当前 lane 是否小于 pivot
    emit br_if cond=%vc, then_pc=pivot_label, else_pc=else_label # 条件为 false 时直接选择 else lane
    emit br_if cond=%vm, then_pc=then_label, else_pc=else_label # 条件为 true 时继续检查 lane < pivot
    emit mov dst=%vr, src=%vt, width=type_width(%field) # then 片段复制当前 lane
    emit br target=join_label # then 片段跳转到当前 lane 汇合点
    emit mov dst=%vr, src=%ve, width=type_width(%field) # else 片段复制当前 lane；lane >= pivot 也走这里
    bind %r = %vr # 记录当前 lane 临时绑定，merge 的所有结果 lane 都有定义
  } # 结束 VP 固定向量 merge lowering 动作
} # 结束 VP 固定向量 merge 规则

rule llvm.experimental.vp.reverse.element { # 将 VP 固定向量 reverse 的激活 lane 降低为 VM 复制
  match %r = llvm.experimental.vp.reverse vector %value, const_mask %mask, const_evl %evl # 匹配常量 mask/EVL 的 fixed vector VP reverse
