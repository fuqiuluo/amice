rule llvm.vector.insert.dynamic_element { # 将动态下标 insertelement 降低为逐 lane 条件复制
  match %r = llvm.insertelement vector %vec, scalar %element, dynamic_index %lane # 匹配固定向量的运行时 lane 插入
  lower { # 开始声明动态 insertelement lowering 动作
    %vi = materialize %lane as integer # 将运行时 lane 下标物化为 VM 整数寄存器
    %vk = vreg integer # 为当前候选 lane 常量分配 VM 寄存器
    %vm = vreg i1 # 为 lane 命中比较结果分配 VM 布尔寄存器
    %ve = materialize %element as scalar # 将待插入元素物化为 VM 标量寄存器
    %vo = materialize %original_lane as scalar # 将当前原始 lane 物化为 VM 标量寄存器
    %vr = vreg scalar # 为当前结果 lane 分配 VM 标量寄存器
    emit mov_imm dst=%vk, imm=lane(%r), width=type_width(%index) # 把当前候选 lane 编号写入比较寄存器
    emit icmp pred=eq, dst=%vm, lhs=%vi, rhs=%vk, width=type_width(%index) # 比较运行时下标是否等于当前 lane
    emit br_if cond=%vm, then_pc=case_label, else_pc=next_case_label # 命中则写入新元素，否则保留原 lane
    emit mov dst=%vr, src=%ve, width=type_width(%element) # 命中分支复制新元素到当前结果 lane
    emit br target=join_label # 命中分支跳转到当前 lane 汇合点
    emit mov dst=%vr, src=%vo, width=type_width(%element) # 未命中分支复制原始 lane 到结果 lane
    bind %r = %vr # 记录当前结果 lane 临时绑定，translator 会组成固定向量结果
  } # 结束动态 insertelement lowering 动作
} # 结束动态 insertelement 规则

