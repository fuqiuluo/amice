  match %r = llvm.ptr.annotation pointer %value # 匹配返回原始指针值的 ptr.annotation intrinsic
  lower { # 开始声明 ptr.annotation lowering 动作
    %vv = materialize %value as ptr # 将源指针物化为 VM x 寄存器中的 64 位地址
    %vr = vreg ptr # 为 ptr.annotation 返回指针分配一个 VM x 寄存器
    emit mov dst=%vr, src=%vv, width=type_width(%r) # 用 mov 保留指针 bit，忽略注释 metadata
    bind %r = %vr # 记录 LLVM ptr.annotation 结果到 VM 寄存器的绑定
  } # 结束 ptr.annotation lowering 动作
} # 结束 ptr.annotation 规则

rule llvm.ptrmask.pointer { # 将 LLVM ptrmask 指针 intrinsic 降低为独立 ptrmask VM 指令
  match %r = llvm.ptrmask pointer %ptr, %mask # 匹配返回按整数 mask 清除低位后的指针 intrinsic
  lower { # 开始声明 ptrmask lowering 动作
    %vp = materialize %ptr as ptr # 将源指针物化为 VM x 寄存器中的 64 位地址
    %vm = materialize %mask as integer # 将整数 mask 物化为 VM x 寄存器中的 64 位掩码
    %vr = vreg ptr # 为 ptrmask 返回指针分配一个 VM x 寄存器
    emit ptrmask dst=%vr, lhs=%vp, rhs=%vm, width=type_width(%r) # 发射 profile ISA 中的 ptrmask 指令
    bind %r = %vr # 记录 LLVM ptrmask 结果到 VM 寄存器的绑定
  } # 结束 ptrmask lowering 动作
} # 结束 ptrmask 规则

rule llvm.threadlocal.address.pointer { # 将 LLVM threadlocal.address 指针 intrinsic 降低为独立 tls_addr VM 指令
  match %r = llvm.threadlocal.address pointer %value # 匹配返回线程本地对象运行时地址的 intrinsic
  lower { # 开始声明 threadlocal.address lowering 动作
    %vv = materialize %value as ptr # 将源线程本地指针物化为 VM x 寄存器中的 64 位地址
    %vr = vreg ptr # 为 threadlocal.address 返回指针分配一个 VM x 寄存器
    emit tls_addr dst=%vr, src=%vv, width=type_width(%r) # 发射 profile ISA 中的 tls_addr 指令
    bind %r = %vr # 记录 LLVM threadlocal.address 结果到 VM 寄存器的绑定
  } # 结束 threadlocal.address lowering 动作
} # 结束 threadlocal.address 规则

rule llvm.global.address.pointer { # 将普通 LLVM GlobalValue 指针物化为独立 global_addr VM 指令
  match %r = llvm.global.address pointer %value # 匹配 translator 合成的全局符号地址 materialize 动作
  lower { # 开始声明 global address lowering 动作
    %vv = materialize %value as ptr # 将 native thunk 返回的全局地址物化为 VM x 寄存器值
    %vr = vreg ptr # 为全局地址结果声明一个 VM x 寄存器，translator 可预先绑定该寄存器
    emit global_addr dst=%vr, src=%vv, width=type_width(%r) # 包装 native thunk 返回的运行时全局地址
    bind %r = %vr # 记录 synthetic global address 结果到 VM 寄存器绑定
  } # 结束 global address lowering 动作
} # 结束 global address 规则

rule llvm.var.annotation { # 将 LLVM var.annotation 变量注释 intrinsic 降低为显式 VM 空操作
  match llvm.var.annotation %ptr # 匹配只携带注释 metadata、不改变运行时内存的变量注释 intrinsic
  lower { # 开始声明 var.annotation lowering 动作
    emit fake_nop # 发射不改变 VM 状态的 profile 指令，保留字节码位置扰动
  } # 结束 var.annotation lowering 动作
} # 结束 var.annotation 规则

rule llvm.codeview.annotation { # 将 LLVM codeview.annotation 调试注释 intrinsic 降低为显式 VM 空操作
  match llvm.codeview.annotation metadata # 匹配只产生调试注释副作用的 codeview annotation intrinsic
  lower { # 开始声明 codeview.annotation lowering 动作
    emit fake_nop # 运行时不重新产生调试记录，仅保留 profile 驱动的 VM 空操作
  } # 结束 codeview.annotation lowering 动作
} # 结束 codeview.annotation 规则

rule llvm.lifetime.start { # 将 LLVM lifetime.start metadata intrinsic 降低为显式 VM 空操作
  match llvm.lifetime.start %ptr # 匹配声明对象生命周期开始的 LLVM intrinsic
  lower { # 开始声明 lifetime.start lowering 动作
    emit fake_nop # 发射不改变 VM 状态的 profile 指令，保留字节码位置扰动
  } # 结束 lifetime.start lowering 动作
} # 结束 lifetime.start 规则

rule llvm.lifetime.end { # 将 LLVM lifetime.end metadata intrinsic 降低为显式 VM 空操作
  match llvm.lifetime.end %ptr # 匹配声明对象生命周期结束的 LLVM intrinsic
  lower { # 开始声明 lifetime.end lowering 动作
    emit fake_nop # 发射不改变 VM 状态的 profile 指令，保留字节码位置扰动
  } # 结束 lifetime.end lowering 动作
} # 结束 lifetime.end 规则

rule llvm.assume { # 将 LLVM assume 优化提示降低为显式 VM 空操作
  match llvm.assume %cond # 匹配只向优化器提供假设的 llvm.assume intrinsic
  lower { # 开始声明 assume lowering 动作
    emit fake_nop # 不在 VM 中重新检查条件，仅保留 profile 驱动的字节码扰动
  } # 结束 assume lowering 动作
} # 结束 assume 规则

rule llvm.dbg.nop { # 将 LLVM 调试信息 intrinsic 降低为显式 VM 空操作
  match llvm.dbg intrinsic # 匹配不影响运行时语义的 llvm.dbg.* intrinsic
  lower { # 开始声明 dbg lowering 动作
    emit fake_nop # 保留一条可见 VM 空操作，避免调试信息导致整函数跳过
  } # 结束 dbg lowering 动作
} # 结束 dbg 规则

rule llvm.const_pool.materialize { # 将较大的 LLVM 整数常量降低为常量池读取
  match %v = llvm.constant integer # 匹配需要放入常量池的整数常量
  lower { # 开始声明常量池 materialize 动作
    %vr = vreg integer # 为常量分配一个 VM x 寄存器
    emit const_load dst=%vr, index=const_pool_index(%v), width=type_width(%v) # 从 profile 字节码常量池读取常量
    bind %v = %vr # 记录常量到 VM 寄存器的绑定
  } # 结束常量池 materialize 动作
} # 结束常量池 materialize 规则

rule llvm.alloca.stack { # 将固定大小 LLVM alloca 降低为 VM 栈分配
  match %r = llvm.alloca fixed %ty # 匹配固定元素个数的 alloca
  lower { # 开始声明 alloca lowering 动作
    %vr = vreg ptr # 为栈槽地址分配一个 VM x 寄存器
    emit alloca dst=%vr, bytes=alloc_size(%ty), align=alloc_align(%r) # 发射 VM 栈分配指令
    bind %r = %vr # 记录 LLVM alloca 指针到 VM 寄存器的绑定
  } # 结束 alloca lowering 动作
} # 结束 alloca 规则

rule llvm.alloca.dynamic { # 将动态元素个数 LLVM alloca 降低为 VM 栈分配
  match %r = llvm.alloca dynamic %count, %ty # 匹配运行时元素个数的 alloca
  lower { # 开始声明动态 alloca lowering 动作
    %vc = materialize %count as integer # 将动态元素个数物化为 VM x 寄存器
    %vr = vreg ptr # 为栈槽地址分配一个 VM x 寄存器
    emit alloca_dyn dst=%vr, count=%vc, elem_size=alloc_elem_size(%ty), align=alloc_align(%r) # 发射动态 VM 栈分配指令
    bind %r = %vr # 记录 LLVM alloca 指针到 VM 寄存器的绑定
  } # 结束动态 alloca lowering 动作
} # 结束动态 alloca 规则

rule llvm.memory.scalar { # 将标量整数 load/store 降低为 VM 地址寄存器访问
  match llvm.memory scalar %ptr # 匹配标量 load 或 store
  lower { # 开始声明内存 lowering 动作
    %vp = materialize %ptr as ptr # 将内存地址物化为 VM 指针值
    %vv = vreg integer # 为 load 结果或 store 源值保留 VM x 寄存器
    emit load dst=%vv, ptr=%vp, width=memory_width(%ptr) # load 发射 load 指令
    emit store src=%vv, ptr=%vp, width=memory_width(%ptr) # store 发射 store 指令
    bind %r = %vv # load 时记录 LLVM 结果到 VM 寄存器，store 路径没有 %r 绑定目标
  } # 结束内存 lowering 动作
} # 结束内存规则

rule llvm.memory.volatile.scalar { # 将 volatile 标量 load/store 降低为 VM volatile 地址访问
  match llvm.memory volatile scalar %ptr # 匹配 volatile 标量 load 或 store
  lower { # 开始声明 volatile 内存 lowering 动作
    %vp = materialize %ptr as ptr # 将 volatile 内存地址物化为 VM 指针值
    %vv = vreg integer # 为 volatile load 结果或 volatile store 源值保留 VM x 寄存器
    emit volatile_load dst=%vv, ptr=%vp, width=memory_width(%ptr) # volatile load 发射 volatile_load 指令
    emit volatile_store src=%vv, ptr=%vp, width=memory_width(%ptr) # volatile store 发射 volatile_store 指令
    bind %r = %vv # volatile load 时记录 LLVM 结果到 VM 寄存器，store 路径没有 %r 绑定目标
  } # 结束 volatile 内存 lowering 动作
} # 结束 volatile 内存规则

rule llvm.memory.aggregate.load { # 将固定布局聚合 load 展开为逐叶子字段读取
  match %r = llvm.load aggregate %ptr # 匹配结构体或固定数组的非 volatile 普通 load
  lower { # 开始声明聚合 load lowering 动作
    %vp = materialize %ptr as ptr # 将聚合起始地址物化为 VM 指针值
    %addr = vreg ptr # 为非零字段偏移地址分配 VM 指针寄存器
    %vf = vreg scalar # 为当前叶子字段的内存读取结果分配临时 VM 寄存器
    %vr = vreg aggregate # 为当前叶子字段的稳定聚合绑定分配 VM 寄存器
    emit gep dst=%addr, base=%vp, offset=field_offset(%field) # 非零字段偏移时计算字段地址
    emit load dst=%vf, ptr=%vp, width=field_width(%field) # 偏移为 0 的字段直接从聚合起始地址读取
    emit load dst=%vf, ptr=%addr, width=field_width(%field) # 非零偏移字段从计算后的字段地址读取
    emit mov dst=%vr, src=%vf, width=field_width(%field) # 将读取结果稳定复制为聚合字段绑定
    bind %r = %vr # 记录当前字段的临时绑定，translator 会组合成聚合结果
  } # 结束聚合 load lowering 动作
} # 结束聚合 load 规则

rule llvm.memory.aggregate.store { # 将固定布局聚合 store 展开为逐叶子字段写入
  match llvm.store aggregate %ptr, %value # 匹配结构体或固定数组的非 volatile 普通 store
  lower { # 开始声明聚合 store lowering 动作
    %vp = materialize %ptr as ptr # 将聚合目标起始地址物化为 VM 指针值
    %vf = materialize %field as scalar # 将当前待写叶子字段物化为 VM 标量值
    %addr = vreg ptr # 为非零字段偏移地址分配 VM 指针寄存器
    emit gep dst=%addr, base=%vp, offset=field_offset(%field) # 非零字段偏移时计算字段地址
    emit store src=%vf, ptr=%vp, width=field_width(%field) # 偏移为 0 的字段直接写入聚合起始地址
    emit store src=%vf, ptr=%addr, width=field_width(%field) # 非零偏移字段写入计算后的字段地址
  } # 结束聚合 store lowering 动作
} # 结束聚合 store 规则

rule llvm.memory.vector.load { # 将固定向量 load 展开为逐 lane 标量读取
  match %r = llvm.load vector %ptr # 匹配非 volatile fixed vector load
  lower { # 开始声明固定向量 load lowering 动作
    %vp = materialize %ptr as ptr # 将向量起始地址物化为 VM 指针值
    %addr = vreg ptr # 为非零 lane 偏移地址分配 VM 指针寄存器
    %vf = vreg scalar # 为当前 lane 的内存读取结果分配临时 VM 寄存器
    %vr = vreg vector # 为当前 lane 的稳定向量绑定分配 VM 寄存器
    emit gep dst=%addr, base=%vp, offset=lane_offset(%lane) # 非零 lane 偏移时计算 lane 地址
    emit load dst=%vf, ptr=%vp, width=lane_width(%lane) # lane 偏移为 0 时直接从向量起始地址读取
    emit load dst=%vf, ptr=%addr, width=lane_width(%lane) # 非零 lane 偏移时从计算后的 lane 地址读取
    emit mov dst=%vr, src=%vf, width=lane_width(%lane) # 将读取结果稳定复制为向量 lane 绑定
    bind %r = %vr # 记录当前 lane 的临时绑定，translator 会组合成固定向量
  } # 结束固定向量 load lowering 动作
} # 结束固定向量 load 规则

rule llvm.memory.vector.store { # 将固定向量 store 展开为逐 lane 标量写入
  match llvm.store vector %ptr, %value # 匹配非 volatile fixed vector store
  lower { # 开始声明固定向量 store lowering 动作
    %vp = materialize %ptr as ptr # 将向量目标起始地址物化为 VM 指针值
    %vf = materialize %lane as scalar # 将当前待写 lane 物化为 VM 标量值
    %addr = vreg ptr # 为非零 lane 偏移地址分配 VM 指针寄存器
    emit gep dst=%addr, base=%vp, offset=lane_offset(%lane) # 非零 lane 偏移时计算 lane 地址
    emit store src=%vf, ptr=%vp, width=lane_width(%lane) # lane 偏移为 0 时直接写入向量起始地址
    emit store src=%vf, ptr=%addr, width=lane_width(%lane) # 非零 lane 偏移时写入计算后的 lane 地址
  } # 结束固定向量 store lowering 动作
} # 结束固定向量 store 规则

rule llvm.memory.volatile.vector.load { # 将 volatile 固定向量 load 展开为逐 lane volatile 标量读取
  match %r = llvm.load volatile vector %ptr # 匹配 volatile fixed vector load
  lower { # 开始声明 volatile 固定向量 load lowering 动作
    %vp = materialize %ptr as ptr # 将 volatile 向量起始地址物化为 VM 指针值
    %addr = vreg ptr # 为非零 lane 偏移地址分配 VM 指针寄存器
    %vf = vreg scalar # 为当前 lane 的 volatile 读取结果分配临时 VM 寄存器
    %vr = vreg vector # 为当前 lane 的稳定向量绑定分配 VM 寄存器
    emit gep dst=%addr, base=%vp, offset=lane_offset(%lane) # 非零 lane 偏移时计算 lane 地址
    emit volatile_load dst=%vf, ptr=%vp, width=lane_width(%lane) # lane 偏移为 0 时直接 volatile 读取
    emit volatile_load dst=%vf, ptr=%addr, width=lane_width(%lane) # 非零 lane 偏移时从计算后的地址 volatile 读取
    emit mov dst=%vr, src=%vf, width=lane_width(%lane) # 将 volatile 读取结果稳定复制为向量 lane 绑定
    bind %r = %vr # 记录当前 lane 的临时绑定，translator 会组合成固定向量
  } # 结束 volatile 固定向量 load lowering 动作
} # 结束 volatile 固定向量 load 规则

rule llvm.memory.volatile.vector.store { # 将 volatile 固定向量 store 展开为逐 lane volatile 标量写入
  match llvm.store volatile vector %ptr, %value # 匹配 volatile fixed vector store
  lower { # 开始声明 volatile 固定向量 store lowering 动作
    %vp = materialize %ptr as ptr # 将 volatile 向量目标起始地址物化为 VM 指针值
    %vf = materialize %lane as scalar # 将当前待写 lane 物化为 VM 标量值
    %addr = vreg ptr # 为非零 lane 偏移地址分配 VM 指针寄存器
    emit gep dst=%addr, base=%vp, offset=lane_offset(%lane) # 非零 lane 偏移时计算 lane 地址
    emit volatile_store src=%vf, ptr=%vp, width=lane_width(%lane) # lane 偏移为 0 时直接 volatile 写入
    emit volatile_store src=%vf, ptr=%addr, width=lane_width(%lane) # 非零 lane 偏移时写入计算后的地址
  } # 结束 volatile 固定向量 store lowering 动作
} # 结束 volatile 固定向量 store 规则

rule llvm.memory.masked.vector.load { # 将常量 mask 的 fixed vector masked.load 展开为逐 lane 读取或 passthru 复制
  match %r = llvm.masked.load vector %ptr, const_mask %mask, vector %passthru # 匹配 LLVM masked.load，mask 必须是常量 <N x i1>
  lower { # 开始声明 masked.load lowering 动作
    %vp = materialize %ptr as ptr # 将向量起始地址物化为 VM 指针值
    %addr = vreg ptr # 为非零 lane 偏移地址分配 VM 指针寄存器
    %vf = vreg scalar # 为启用 lane 的内存读取结果分配临时 VM 寄存器
    %vpass = materialize %passthru_lane as scalar # 将禁用 lane 的 passthru 值物化为 VM 标量
    %vr = vreg vector # 为当前结果 lane 分配稳定 VM 寄存器
    emit gep dst=%addr, base=%vp, offset=lane_offset(%lane) # 非零 lane 偏移时计算 lane 地址
    emit load dst=%vf, ptr=%vp, width=lane_width(%lane) # mask 为 true 且偏移为 0 时直接读取
    emit load dst=%vf, ptr=%addr, width=lane_width(%lane) # mask 为 true 且非零偏移时从 lane 地址读取
    emit mov dst=%vr, src=%vf, width=lane_width(%lane) # 将启用 lane 的读取值复制为结果 lane
    emit mov dst=%vr, src=%vpass, width=lane_width(%lane) # 将禁用 lane 的 passthru 复制为结果 lane
    bind %r = %vr # 记录当前 lane 绑定，translator 会组合成 fixed vector 结果
  } # 结束 masked.load lowering 动作
} # 结束 masked.load 规则

rule llvm.memory.masked.vector.store { # 将常量 mask 的 fixed vector masked.store 展开为逐 lane 条件写入
  match llvm.masked.store vector %ptr, %value, const_mask %mask # 匹配 LLVM masked.store，mask 必须是常量 <N x i1>
  lower { # 开始声明 masked.store lowering 动作
    %vp = materialize %ptr as ptr # 将向量目标起始地址物化为 VM 指针值
    %vf = materialize %lane as scalar # 将当前启用 lane 的待写值物化为 VM 标量
    %addr = vreg ptr # 为非零 lane 偏移地址分配 VM 指针寄存器
    emit gep dst=%addr, base=%vp, offset=lane_offset(%lane) # 非零 lane 偏移时计算 lane 地址
    emit store src=%vf, ptr=%vp, width=lane_width(%lane) # mask 为 true 且偏移为 0 时直接写入
    emit store src=%vf, ptr=%addr, width=lane_width(%lane) # mask 为 true 且非零偏移时写入 lane 地址
  } # 结束 masked.store lowering 动作
} # 结束 masked.store 规则

rule llvm.memory.masked.vector.expandload { # 将常量 mask 的 fixed vector masked.expandload 展开为按启用 lane 连续读取或 passthru 复制
  match %r = llvm.masked.expandload vector %ptr, const_mask %mask, vector %passthru # 匹配 LLVM masked.expandload，mask 必须是常量 <N x i1>
  lower { # 开始声明 masked.expandload lowering 动作
    %vp = materialize %ptr as ptr # 将压缩读取起始地址物化为 VM 指针值
    %addr = vreg ptr # 为非零启用 lane 累计偏移地址分配 VM 指针寄存器
    %vf = vreg scalar # 为启用 lane 的内存读取结果分配临时 VM 寄存器
    %vpass = materialize %passthru_lane as scalar # 将禁用 lane 的 passthru 值物化为 VM 标量
    %vr = vreg vector # 为当前结果 lane 分配稳定 VM 寄存器
    emit gep dst=%addr, base=%vp, offset=active_offset(%lane) # 非首个启用 lane 按已启用 lane 数计算连续内存地址
    emit load dst=%vf, ptr=%vp, width=lane_width(%lane) # 首个启用 lane 从起始地址直接读取
    emit load dst=%vf, ptr=%addr, width=lane_width(%lane) # 后续启用 lane 从连续压缩地址读取
    emit mov dst=%vr, src=%vf, width=lane_width(%lane) # 将启用 lane 的读取值复制为结果 lane
    emit mov dst=%vr, src=%vpass, width=lane_width(%lane) # 将禁用 lane 的 passthru 复制为结果 lane
    bind %r = %vr # 记录当前 lane 绑定，translator 会组合成 fixed vector 结果
  } # 结束 masked.expandload lowering 动作
} # 结束 masked.expandload 规则

rule llvm.memory.masked.vector.compressstore { # 将常量 mask 的 fixed vector masked.compressstore 展开为按启用 lane 连续写入
  match llvm.masked.compressstore vector %ptr, %value, const_mask %mask # 匹配 LLVM masked.compressstore，mask 必须是常量 <N x i1>
  lower { # 开始声明 masked.compressstore lowering 动作
    %vp = materialize %ptr as ptr # 将压缩写入起始地址物化为 VM 指针值
    %vf = materialize %lane as scalar # 将当前启用 lane 的待写值物化为 VM 标量
    %addr = vreg ptr # 为非零启用 lane 累计偏移地址分配 VM 指针寄存器
    emit gep dst=%addr, base=%vp, offset=active_offset(%lane) # 非首个启用 lane 按已启用 lane 数计算连续内存地址
    emit store src=%vf, ptr=%vp, width=lane_width(%lane) # 首个启用 lane 写入起始地址
    emit store src=%vf, ptr=%addr, width=lane_width(%lane) # 后续启用 lane 写入连续压缩地址
  } # 结束 masked.compressstore lowering 动作
} # 结束 masked.compressstore 规则

rule llvm.memory.masked.vector.gather { # 将常量 mask 的 fixed vector masked.gather 展开为逐 lane 指针读取或 passthru 复制
  match %r = llvm.masked.gather vector %ptrs, const_mask %mask, vector %passthru # 匹配 LLVM masked.gather，指针向量和 mask 必须都是 fixed vector
  lower { # 开始声明 masked.gather lowering 动作
    %vp = materialize %ptr_lane as ptr # 将当前启用 lane 的指针物化为 VM 指针值
    %vf = vreg scalar # 为启用 lane 的读取结果分配临时 VM 寄存器
    %vpass = materialize %passthru_lane as scalar # 将禁用 lane 的 passthru 值物化为 VM 标量
    %vr = vreg vector # 为当前结果 lane 分配稳定 VM 寄存器
    emit load dst=%vf, ptr=%vp, width=lane_width(%lane) # mask 为 true 时从当前 lane 指针读取
    emit mov dst=%vr, src=%vf, width=lane_width(%lane) # 将启用 lane 的读取值复制为结果 lane
    emit mov dst=%vr, src=%vpass, width=lane_width(%lane) # 将禁用 lane 的 passthru 复制为结果 lane
    bind %r = %vr # 记录当前 lane 绑定，translator 会组合成 fixed vector 结果
  } # 结束 masked.gather lowering 动作
} # 结束 masked.gather 规则

rule llvm.memory.masked.vector.scatter { # 将常量 mask 的 fixed vector masked.scatter 展开为逐 lane 指针条件写入
  match llvm.masked.scatter vector %ptrs, %value, const_mask %mask # 匹配 LLVM masked.scatter，指针向量和 mask 必须都是 fixed vector
  lower { # 开始声明 masked.scatter lowering 动作
    %vp = materialize %ptr_lane as ptr # 将当前启用 lane 的目标指针物化为 VM 指针值
    %vf = materialize %lane as scalar # 将当前启用 lane 的待写值物化为 VM 标量
    emit store src=%vf, ptr=%vp, width=lane_width(%lane) # mask 为 true 时写入当前 lane 指针
  } # 结束 masked.scatter lowering 动作
} # 结束 masked.scatter 规则

rule llvm.memory.vp.strided.vector.load { # 将 LLVM vp.strided.load 展开为按动态字节步长逐 lane 读取
  match %r = llvm.experimental.vp.strided.load vector %ptr, integer %stride, const_mask %mask, const_evl %evl # 匹配 fixed vector strided load，stride 可为 i1/i8/i16/i32/i64，mask 和 EVL 必须是常量
  lower { # 开始声明 vp.strided.load lowering 动作
    %vp = materialize %ptr as ptr # 将起始地址物化为 VM 指针值
    %vs = materialize %stride as integer # 将字节步长物化为 VM 整数值
    %vwide = vreg integer # 为窄字节步长扩宽到 64 位保留 VM 整数寄存器
    %vi = vreg integer # 为当前 lane 编号分配 VM 整数寄存器
    %vo = vreg integer # 为 stride 乘以 lane 的动态字节偏移分配 VM 整数寄存器
    %addr = vreg ptr # 为当前 lane 的实际读取地址分配 VM 指针寄存器
    %vf = vreg scalar # 为当前 lane 的读取结果分配临时 VM 寄存器
    %vr = vreg vector # 为当前 lane 的稳定结果分配 VM 寄存器
    emit sext dst=%vwide, src=%vs, from_width=type_width(%stride), to_width=64 # 窄字节步长先按有符号 byte stride 语义扩展到 64 位
    emit imul dst=%vo, lhs=%vwide, rhs=%vi, width=64 # 使用 64 位字节步长计算当前 lane 的动态字节偏移
    emit iadd dst=%addr, lhs=%vp, rhs=%vo, width=64 # 将起始地址和动态偏移相加得到 lane 地址
    emit load dst=%vf, ptr=%vp, width=lane_width(%lane) # lane 0 直接从起始地址读取
    emit load dst=%vf, ptr=%addr, width=lane_width(%lane) # 非零 lane 从动态步长地址读取
    emit mov dst=%vr, src=%vf, width=lane_width(%lane) # 将读取值稳定复制为结果 lane
    bind %r = %vr # 记录当前 lane 绑定，translator 会组合成 fixed vector 结果
  } # 结束 vp.strided.load lowering 动作
} # 结束 vp.strided.load 规则

rule llvm.memory.vp.strided.vector.store { # 将 LLVM vp.strided.store 展开为按动态字节步长逐 lane 写入
  match llvm.experimental.vp.strided.store vector %ptr, %value, integer %stride, const_mask %mask, const_evl %evl # 匹配 fixed vector strided store，stride 可为 i1/i8/i16/i32/i64，mask 和 EVL 必须是常量
  lower { # 开始声明 vp.strided.store lowering 动作
    %vp = materialize %ptr as ptr # 将起始地址物化为 VM 指针值
    %vf = materialize %lane as scalar # 将当前启用 lane 的待写值物化为 VM 标量
    %vs = materialize %stride as integer # 将字节步长物化为 VM 整数值
    %vwide = vreg integer # 为窄字节步长扩宽到 64 位保留 VM 整数寄存器
    %vi = vreg integer # 为当前 lane 编号分配 VM 整数寄存器
    %vo = vreg integer # 为 stride 乘以 lane 的动态字节偏移分配 VM 整数寄存器
    %addr = vreg ptr # 为当前 lane 的实际写入地址分配 VM 指针寄存器
    emit sext dst=%vwide, src=%vs, from_width=type_width(%stride), to_width=64 # 窄字节步长先按有符号 byte stride 语义扩展到 64 位
    emit imul dst=%vo, lhs=%vwide, rhs=%vi, width=64 # 使用 64 位字节步长计算当前 lane 的动态字节偏移
    emit iadd dst=%addr, lhs=%vp, rhs=%vo, width=64 # 将起始地址和动态偏移相加得到 lane 地址
    emit store src=%vf, ptr=%vp, width=lane_width(%lane) # lane 0 直接写入起始地址
    emit store src=%vf, ptr=%addr, width=lane_width(%lane) # 非零 lane 写入动态步长地址
  } # 结束 vp.strided.store lowering 动作
} # 结束 vp.strided.store 规则

rule llvm.memory.volatile.aggregate.load { # 将 volatile 聚合 load 展开为逐叶子字段 volatile 读取
  match %r = llvm.load volatile aggregate %ptr # 匹配结构体或固定数组的 volatile load
  lower { # 开始声明 volatile 聚合 load lowering 动作
    %vp = materialize %ptr as ptr # 将 volatile 聚合起始地址物化为 VM 指针值
    %addr = vreg ptr # 为非零字段偏移地址分配 VM 指针寄存器
    %vf = vreg scalar # 为当前叶子字段的 volatile 读取结果分配临时 VM 寄存器
    %vr = vreg aggregate # 为当前叶子字段的稳定聚合绑定分配 VM 寄存器
    emit gep dst=%addr, base=%vp, offset=field_offset(%field) # 非零字段偏移时计算字段地址
    emit volatile_load dst=%vf, ptr=%vp, width=field_width(%field) # 偏移为 0 的字段直接从聚合起始地址 volatile 读取
    emit volatile_load dst=%vf, ptr=%addr, width=field_width(%field) # 非零偏移字段从计算后的字段地址 volatile 读取
    emit mov dst=%vr, src=%vf, width=field_width(%field) # 将 volatile 读取结果稳定复制为聚合字段绑定
    bind %r = %vr # 记录当前字段的临时绑定，translator 会组合成聚合结果
  } # 结束 volatile 聚合 load lowering 动作
} # 结束 volatile 聚合 load 规则

rule llvm.memory.volatile.aggregate.store { # 将 volatile 聚合 store 展开为逐叶子字段 volatile 写入
  match llvm.store volatile aggregate %ptr, %value # 匹配结构体或固定数组的 volatile store
  lower { # 开始声明 volatile 聚合 store lowering 动作
    %vp = materialize %ptr as ptr # 将 volatile 聚合目标起始地址物化为 VM 指针值
    %vf = materialize %field as scalar # 将当前待写叶子字段物化为 VM 标量值
    %addr = vreg ptr # 为非零字段偏移地址分配 VM 指针寄存器
    emit gep dst=%addr, base=%vp, offset=field_offset(%field) # 非零字段偏移时计算字段地址
    emit volatile_store src=%vf, ptr=%vp, width=field_width(%field) # 偏移为 0 的字段直接 volatile 写入聚合起始地址
    emit volatile_store src=%vf, ptr=%addr, width=field_width(%field) # 非零偏移字段 volatile 写入计算后的字段地址
  } # 结束 volatile 聚合 store lowering 动作
} # 结束 volatile 聚合 store 规则

rule llvm.memory.volatile.empty_aggregate.load { # 将 volatile 空聚合 load 降低为显式副作用屏障
  match llvm.load volatile empty_aggregate %ptr # 匹配没有 VM 标量结果但仍带 volatile 语义的空聚合读取
  lower { # 开始声明 volatile 空聚合 load lowering 动作
    %vp = materialize %ptr as ptr # 物化指针以保持 profile 对地址 operand 的校验边界
    emit sideeffect # 发射 sideeffect，保留 volatile 空内存访问的可见顺序约束
  } # 结束 volatile 空聚合 load lowering 动作
} # 结束 volatile 空聚合 load 规则

rule llvm.memory.volatile.empty_aggregate.store { # 将 volatile 空聚合 store 降低为显式副作用屏障
  match llvm.store volatile empty_aggregate %ptr, %value # 匹配没有叶子字段但仍带 volatile 语义的聚合写入
  lower { # 开始声明 volatile 空聚合 store lowering 动作
    %vp = materialize %ptr as ptr # 物化指针以保持 profile 对地址 operand 的校验边界
    emit sideeffect # 发射 sideeffect，保留 volatile 空内存访问的可见顺序约束
  } # 结束 volatile 空聚合 store lowering 动作
} # 结束 volatile 空聚合 store 规则

rule llvm.atomic.load.scalar { # 将自然对齐整数、指针、f16/f32/f64 标量 atomic load 降低为 VM atomic_load 指令
  match %r = llvm.atomic.load scalar %ptr # 匹配已由 translator 校验过 ordering 和自然对齐的 atomic load
  lower { # 开始声明 atomic load lowering 动作
    %vp = materialize %ptr as ptr # 将原子读取地址物化为 VM 指针值
    %vr = vreg integer # 为 atomic load 结果分配 VM x 寄存器
    emit atomic_load dst=%vr, ptr=%vp, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 发射携带 ordering 和 syncscope 的 atomic_load 指令
    bind %r = %vr # 记录 LLVM atomic load 结果到 VM 寄存器的绑定
  } # 结束 atomic load lowering 动作
} # 结束 atomic load 规则

rule llvm.atomic.store.scalar { # 将自然对齐整数、指针、f16/f32/f64 标量 atomic store 降低为 VM atomic_store 指令
  match llvm.atomic.store scalar %ptr # 匹配已由 translator 校验过 ordering 和自然对齐的 atomic store
  lower { # 开始声明 atomic store lowering 动作
    %vp = materialize %ptr as ptr # 将原子写入地址物化为 VM 指针值
    %vv = vreg integer # 为原子写入值声明 VM x 寄存器，translator 会绑定真实 store 源值
    emit atomic_store src=%vv, ptr=%vp, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 发射携带 ordering 和 syncscope 的 atomic_store 指令
  } # 结束 atomic store lowering 动作
} # 结束 atomic store 规则

rule llvm.atomic.volatile.load.scalar { # 将自然对齐整数、指针、f16/f32/f64 标量 volatile atomic load 降低为 VM volatile_atomic_load 指令
  match %r = llvm.atomic.volatile.load scalar %ptr # 匹配已由 translator 校验过 ordering、volatile 和自然对齐的 atomic load
  lower { # 开始声明 volatile atomic load lowering 动作
    %vp = materialize %ptr as ptr # 将 volatile 原子读取地址物化为 VM 指针值
    %vr = vreg integer # 为 volatile atomic load 结果分配 VM x 寄存器
    emit volatile_atomic_load dst=%vr, ptr=%vp, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 发射同时携带 volatile、ordering 和 syncscope 语义的 load 指令
    bind %r = %vr # 记录 LLVM volatile atomic load 结果到 VM 寄存器的绑定
  } # 结束 volatile atomic load lowering 动作
} # 结束 volatile atomic load 规则

rule llvm.atomic.volatile.store.scalar { # 将自然对齐整数、指针、f16/f32/f64 标量 volatile atomic store 降低为 VM volatile_atomic_store 指令
  match llvm.atomic.volatile.store scalar %ptr # 匹配已由 translator 校验过 ordering、volatile 和自然对齐的 atomic store
  lower { # 开始声明 volatile atomic store lowering 动作
    %vp = materialize %ptr as ptr # 将 volatile 原子写入地址物化为 VM 指针值
    %vv = vreg integer # 为 volatile 原子写入值声明 VM x 寄存器，translator 会绑定真实 store 源值
    emit volatile_atomic_store src=%vv, ptr=%vp, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 发射同时携带 volatile、ordering 和 syncscope 语义的 store 指令
  } # 结束 volatile atomic store lowering 动作
} # 结束 volatile atomic store 规则

rule llvm.atomic.rmw.scalar { # 将自然对齐标量 atomicrmw 降低为对应 VM atomic_rmw 指令
  match %r = llvm.atomic.rmw scalar %ptr, %value # 匹配已由 translator 校验过 op、ordering 和自然对齐的 atomicrmw
  lower { # 开始声明 atomicrmw lowering 动作
    %vp = materialize %ptr as ptr # 将原子读改写地址物化为 VM 指针值
    %vv = vreg integer # 为读改写输入 bit 声明 VM x 寄存器，整数和浮点 atomicrmw 都复用 x 寄存器原始 bit
    %vr = vreg integer # 为 atomicrmw 返回的旧值分配 VM x 寄存器
    emit atomic_rmw_xchg dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 原子交换路径发射携带 syncscope 的 atomic_rmw_xchg 指令
    emit atomic_rmw_add dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 原子加法路径发射携带 syncscope 的 atomic_rmw_add 指令
    emit atomic_rmw_sub dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 原子减法路径发射携带 syncscope 的 atomic_rmw_sub 指令
    emit atomic_rmw_and dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 原子按位与路径发射携带 syncscope 的 atomic_rmw_and 指令
    emit atomic_rmw_or dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 原子按位或路径发射携带 syncscope 的 atomic_rmw_or 指令
    emit atomic_rmw_xor dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 原子按位异或路径发射携带 syncscope 的 atomic_rmw_xor 指令
    emit atomic_rmw_nand dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 原子按位与取反路径发射携带 syncscope 的 atomic_rmw_nand 指令
    emit atomic_rmw_max dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 有符号最大值路径发射携带 syncscope 的 atomic_rmw_max 指令
    emit atomic_rmw_min dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 有符号最小值路径发射携带 syncscope 的 atomic_rmw_min 指令
    emit atomic_rmw_umax dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 无符号最大值路径发射携带 syncscope 的 atomic_rmw_umax 指令
    emit atomic_rmw_umin dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 无符号最小值路径发射携带 syncscope 的 atomic_rmw_umin 指令
    emit atomic_rmw_uinc_wrap dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 无符号加一回绕路径发射携带 syncscope 的 atomic_rmw_uinc_wrap 指令
    emit atomic_rmw_udec_wrap dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 无符号减一回绕路径发射携带 syncscope 的 atomic_rmw_udec_wrap 指令
    emit atomic_rmw_usub_cond dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 条件无符号减法路径发射携带 syncscope 的 atomic_rmw_usub_cond 指令
    emit atomic_rmw_usub_sat dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 无符号饱和减法路径发射携带 syncscope 的 atomic_rmw_usub_sat 指令
    emit atomic_rmw_fadd dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 浮点加法路径发射携带 syncscope 的 atomic_rmw_fadd 指令，src 是 IEEE 原始 bit
    emit atomic_rmw_fsub dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 浮点减法路径发射携带 syncscope 的 atomic_rmw_fsub 指令，src 是 IEEE 原始 bit
    emit atomic_rmw_fmax dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 浮点最大值路径发射携带 syncscope 的 atomic_rmw_fmax 指令
    emit atomic_rmw_fmin dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # 浮点最小值路径发射携带 syncscope 的 atomic_rmw_fmin 指令
    emit atomic_rmw_fmaximum dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # IEEE maximum 路径发射携带 syncscope 的 atomic_rmw_fmaximum 指令
    emit atomic_rmw_fminimum dst=%vr, ptr=%vp, src=%vv, width=memory_width(%ptr), ordering=memory_ordering(%ptr), sync_scope=sync_scope(%ptr) # IEEE minimum 路径发射携带 syncscope 的 atomic_rmw_fminimum 指令
    bind %r = %vr # 记录 LLVM atomicrmw 返回旧值到 VM 寄存器的绑定
  } # 结束 atomicrmw lowering 动作
} # 结束 atomicrmw 规则

