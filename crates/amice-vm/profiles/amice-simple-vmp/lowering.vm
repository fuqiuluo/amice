    %vr = vreg scalar # 为稳定后的 lane 结果分配 VM x 寄存器
    emit mov dst=%vr, src=%ve, width=type_width(%element) # 用 mov 稳定该 lane 的 bit pattern
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会写入向量字段槽
  } # 结束固定向量 insertelement lowering 动作
