rule llvm.vp.vector.fcmp.float { # 将 VP 固定浮点向量 fcmp 的激活 lane 拆成逐 lane fcmp
  match %r = llvm.vp.fcmp vector float %a, %b, %mask, %evl # 匹配带 metadata 谓词、常量 mask 和常量 EVL 的 fixed vector VP fcmp
  lower { # 开始声明 VP 固定浮点向量 fcmp lowering 动作
    %va = materialize %a_lane as float # 将当前激活左侧 lane 的浮点位模式物化为 VM 值
    %vb = materialize %b_lane as float # 将当前激活右侧 lane 的浮点位模式物化为 VM 值
    %vr = vreg i1 # 为当前激活比较结果 lane 分配一个布尔 VM x 寄存器
    emit fcmp pred=predicate(%r), dst=%vr, lhs=%va, rhs=%vb, width=operand_width(%a,%b) # 用 fcmp 计算当前激活 lane
    bind %r = %vr # 记录当前激活 lane 绑定，未激活 lane 由 translator 保留为 poison
  } # 结束 VP 固定浮点向量 fcmp lowering 动作
} # 结束 VP 固定浮点向量 fcmp 规则

rule llvm.is.fpclass.float { # 将 LLVM is.fpclass 降低为 fpclass VM 指令
  match %r = llvm.is.fpclass float %a, mask # 匹配 f16/f32/f64 标量浮点分类 intrinsic
  lower { # 开始声明 fpclass 的 lowering 动作
    %va = materialize %a as float # 将待分类的浮点 bit 物化为 VM 值
    %vr = vreg i1 # 为分类结果分配一个布尔 VM x 寄存器
    emit fpclass dst=%vr, src=%va, mask=fpclass_mask(%r), width=type_width(%a) # 发射 profile ISA 中的 fpclass 指令
    bind %r = %vr # 记录 LLVM 分类结果到 VM 寄存器的绑定
  } # 结束 fpclass lowering 动作
} # 结束 fpclass 规则

rule llvm.vector.is.fpclass.float { # 将固定浮点向量 is.fpclass 降低为逐 lane 的 fpclass VM 指令
  match %r = llvm.is.fpclass vector float %a, mask # 匹配 f16/f32/f64 固定浮点向量分类 intrinsic
  lower { # 开始声明固定向量 fpclass lowering 动作
    %va = materialize %a_lane as float # 将当前待分类 lane 的浮点 bit 物化为 VM 值
    %vr = vreg i1 # 为当前分类结果 lane 分配一个布尔 VM x 寄存器
    emit fpclass dst=%vr, src=%va, mask=fpclass_mask(%r), width=type_width(%a) # 发射当前 lane 的 fpclass 指令
    bind %r = %vr # 记录当前 lane 的分类结果，translator 会重新组成固定向量
  } # 结束固定向量 fpclass lowering 动作
} # 结束固定向量 fpclass 规则

rule llvm.vp.vector.is.fpclass.float { # 将 VP 固定浮点向量 is.fpclass 的激活 lane 降低为 fpclass VM 指令
  match %r = llvm.vp.is.fpclass vector float %a, mask, const_mask %vp_mask, const_evl %evl # 匹配常量 VP mask/EVL 的浮点向量分类 intrinsic
  lower { # 开始声明 VP 固定向量 fpclass lowering 动作
    %va = materialize %a_lane as float # 将当前激活待分类 lane 的浮点 bit 物化为 VM 值
    %vr = vreg i1 # 为当前激活分类结果 lane 分配一个布尔 VM x 寄存器
    emit fpclass dst=%vr, src=%va, mask=fpclass_mask(%r), width=type_width(%a) # 发射当前激活 lane 的 fpclass 指令
    bind %r = %vr # 记录当前激活 lane 的分类结果，未激活 lane 由 translator 保留为 poison
  } # 结束 VP 固定向量 fpclass lowering 动作
} # 结束 VP 固定向量 fpclass 规则

rule llvm.cast.integer { # 将 zext、sext、trunc、bitcast 降低为 VM 转换指令
  match %r = llvm.cast integer %a # 匹配受支持整数转换
  lower { # 开始声明整数转换 lowering 动作
    %va = materialize %a as integer # 将源值物化为 VM 整数值
    %vr = vreg integer # 为转换结果分配一个 VM x 寄存器
    emit zext dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # zext 发射 zext 指令
    emit sext dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # sext 发射 sext 指令
    emit trunc dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # trunc 发射 trunc 指令
    emit bitcast dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # bitcast 发射 bitcast 指令
    bind %r = %vr # 记录 LLVM 转换结果到 VM 寄存器的绑定
  } # 结束整数转换 lowering 动作
} # 结束整数转换规则

rule llvm.vector.cast.integer { # 将固定整数向量 zext、sext、trunc 降低为逐 lane 的转换 VM 指令
  match %r = llvm.cast vector integer %a # 匹配 lane 数相同的固定整数向量转换
  lower { # 开始声明固定整数向量转换 lowering 动作
    %va = materialize %a_lane as integer # 将当前源 lane 的整数 bit 物化为 VM x 寄存器值
    %vr = vreg integer # 为当前结果 lane 分配 VM x 寄存器
    emit zext dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # vector zext 发射当前 lane 的 zext 指令
    emit sext dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # vector sext 发射当前 lane 的 sext 指令
    emit trunc dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # vector trunc 发射当前 lane 的 trunc 指令
    bind %r = %vr # 记录当前 lane 的转换结果，translator 会重新组成固定向量
  } # 结束固定整数向量转换 lowering 动作
} # 结束固定整数向量转换规则

rule llvm.vp.vector.cast.integer { # 将 VP 固定整数向量 zext、sext、trunc 的激活 lane 降低为逐 lane 转换
  match %r = llvm.vp.cast vector integer %a, %mask, %evl # 匹配常量 mask 和常量 EVL 的 fixed vector VP 整数转换
  lower { # 开始声明 VP 固定整数向量转换 lowering 动作
    %va = materialize %a_lane as integer # 将当前激活源 lane 的整数 bit 物化为 VM x 寄存器值
    %vr = vreg integer # 为当前激活结果 lane 分配 VM x 寄存器
    emit zext dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # VP zext 发射当前激活 lane 的 zext 指令
    emit sext dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # VP sext 发射当前激活 lane 的 sext 指令
    emit trunc dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # VP trunc 发射当前激活 lane 的 trunc 指令
    bind %r = %vr # 记录当前激活 lane 的转换结果，未激活 lane 由 translator 保留为 poison
  } # 结束 VP 固定整数向量转换 lowering 动作
} # 结束 VP 固定整数向量转换规则

rule llvm.cast.pointer { # 将 ptrtoint 和 inttoptr 归一化为 x 寄存器中的宽度转换
  match %r = llvm.cast pointer %a # 匹配指针与整数之间的转换
  lower { # 开始声明指针转换 lowering 动作
    %va = materialize %a as i64 # 将源指针或整数物化为 64 位 VM 值
    %vr = vreg i64 # 为转换结果分配一个 VM x 寄存器
    emit zext dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 窄整数转指针时使用 zext
    emit trunc dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 指针转窄整数时使用 trunc
    emit bitcast dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 同宽转换使用 bitcast
    bind %r = %vr # 记录 LLVM 转换结果到 VM 寄存器的绑定
  } # 结束指针转换 lowering 动作
} # 结束指针转换规则

rule llvm.vector.cast.pointer { # 将固定指针向量 ptrtoint、inttoptr 和 addrspacecast 降低为逐 lane 的宽度转换
  match %r = llvm.cast vector pointer %a # 匹配 lane 数相同的固定指针/整数向量转换
  lower { # 开始声明固定指针向量转换 lowering 动作
    %va = materialize %a_lane as scalar # 将当前源 lane 的指针或整数 bit 物化为 VM x 寄存器值
    %vr = vreg scalar # 为当前结果 lane 分配 VM x 寄存器
    emit zext dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 窄整数 lane 转指针 lane 时使用 zext
    emit trunc dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 指针 lane 转窄整数 lane 时使用 trunc
    emit bitcast dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 同宽指针/整数 lane 转换使用 bitcast
    bind %r = %vr # 记录当前 lane 的转换结果，translator 会重新组成固定向量
  } # 结束固定指针向量转换 lowering 动作
} # 结束固定指针向量转换规则

rule llvm.vp.vector.cast.pointer { # 将 VP 固定指针向量 ptrtoint 和 inttoptr 的激活 lane 降低为逐 lane 宽度转换
  match %r = llvm.vp.cast vector pointer %a, %mask, %evl # 匹配常量 mask 和常量 EVL 的 fixed vector VP 指针/整数转换
  lower { # 开始声明 VP 固定指针向量转换 lowering 动作
    %va = materialize %a_lane as scalar # 将当前激活源 lane 的指针或整数 bit 物化为 VM x 寄存器值
    %vr = vreg scalar # 为当前激活结果 lane 分配 VM x 寄存器
    emit zext dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 窄整数激活 lane 转指针 lane 时使用 zext
    emit trunc dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 指针激活 lane 转窄整数 lane 时使用 trunc
    emit bitcast dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 同宽指针/整数激活 lane 转换使用 bitcast
    bind %r = %vr # 记录当前激活 lane 的转换结果，未激活 lane 由 translator 保留为 poison
  } # 结束 VP 固定指针向量转换 lowering 动作
} # 结束 VP 固定指针向量转换规则

rule llvm.cast.bitcast.scalar { # 将同宽标量 bitcast 降低为 VM bit 保留转换
  match %r = llvm.bitcast scalar %a # 匹配整数、float 或 double 之间的同宽 bitcast
  lower { # 开始声明标量 bitcast lowering 动作
    %va = materialize %a as scalar # 将源标量按原始 bit 物化到 VM x 寄存器
    %vr = vreg scalar # 为 bitcast 结果分配 VM x 寄存器
    emit bitcast dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 同宽 bitcast 保留原始 bit pattern
    bind %r = %vr # 记录 LLVM bitcast 结果到 VM 寄存器绑定
  } # 结束标量 bitcast lowering 动作
} # 结束标量 bitcast 规则

rule llvm.vector.bitcast.element { # 将固定向量 bitcast 降低为逐 lane 的 bitcast VM 指令
  match %r = llvm.bitcast vector %a # 匹配 lane 数相同且 lane 位宽相同的固定向量 bitcast
  lower { # 开始声明固定向量 bitcast lowering 动作
    %va = materialize %a_lane as scalar # 将当前源 lane 的原始 bit 物化为 VM x 寄存器值
    %vr = vreg scalar # 为当前结果 lane 分配 VM x 寄存器
    emit bitcast dst=%vr, src=%va, from_width=type_width(%a), to_width=type_width(%r) # 当前只允许 from_width 等于 to_width
    bind %r = %vr # 记录当前 lane 的 bitcast 结果，translator 会重新组成固定向量
  } # 结束固定向量 bitcast lowering 动作
} # 结束固定向量 bitcast 规则

rule llvm.constexpr.integer.binop { # 将 LLVM 整数二元常量表达式降低为 profile 驱动的整数 VM 指令
  match %r = llvm.constexpr.binop integer %a, %b # 匹配常量表达式形式的整数二元运算
  lower { # 开始声明整数二元常量表达式 lowering 动作
    %va = materialize %a as integer # 将左侧常量表达式 operand 递归物化为 VM 整数值
    %vb = materialize %b as integer # 将右侧常量表达式 operand 递归物化为 VM 整数值
    %vr = vreg integer # 为常量表达式结果分配一个 VM x 寄存器
    emit iadd dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # add 常量表达式发射 iadd 指令
    emit isub dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # sub 常量表达式发射 isub 指令
    emit imul dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # mul 常量表达式发射 imul 指令
    emit iudiv dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # udiv 常量表达式发射 iudiv 指令
    emit isdiv dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # sdiv 常量表达式发射 isdiv 指令
    emit iurem dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # urem 常量表达式发射 iurem 指令
    emit isrem dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # srem 常量表达式发射 isrem 指令
    emit ixor dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # xor 常量表达式发射 ixor 指令
    emit iand dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # and 常量表达式发射 iand 指令
    emit ior dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # or 常量表达式发射 ior 指令
    emit ishl dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # shl 常量表达式发射 ishl 指令
    emit ilshr dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # lshr 常量表达式发射 ilshr 指令
    emit iashr dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # ashr 常量表达式发射 iashr 指令
    bind %r = %vr # 记录整数二元常量表达式结果到 VM 寄存器绑定
  } # 结束整数二元常量表达式 lowering 动作
} # 结束整数二元常量表达式规则

rule llvm.constexpr.integer.cast { # 将 LLVM 整数 cast 常量表达式降低为 profile 驱动的转换 VM 指令
  match %r = llvm.constexpr.cast integer %value # 匹配常量表达式形式的整数转换
  lower { # 开始声明整数 cast 常量表达式 lowering 动作
    %va = materialize %value as integer # 将常量表达式内部整数 operand 递归物化为 VM 整数值
    %vr = vreg integer # 为整数 cast 常量表达式结果分配一个 VM x 寄存器
    emit zext dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # zext 常量表达式发射 zext 指令
    emit sext dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # sext 常量表达式发射 sext 指令
    emit trunc dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # trunc 常量表达式发射 trunc 指令
    emit bitcast dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # bitcast 常量表达式发射 bitcast 指令
    bind %r = %vr # 记录整数 cast 常量表达式结果到 VM 寄存器绑定
  } # 结束整数 cast 常量表达式 lowering 动作
} # 结束整数 cast 常量表达式规则

rule llvm.constexpr.ptrtoint { # 将 LLVM ptrtoint 常量表达式降低为 profile 驱动的指针转整数
  match %r = llvm.constexpr.ptrtoint pointer %value # 匹配常量表达式形式的 ptrtoint 指针值
  lower { # 开始声明 ptrtoint 常量表达式 lowering 动作
    %va = materialize %value as ptr # 将常量表达式内部的指针 operand 物化为运行时 VM 指针值
    %vr = vreg integer # 为 ptrtoint 结果分配一个 VM x 寄存器
    emit zext dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # 目标整数更宽时保留零扩展路径
    emit trunc dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # 目标整数更窄时截断指针 bit
    emit bitcast dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # 同宽 ptrtoint 按 bitcast 保留地址 bit
    bind %r = %vr # 记录 ptrtoint 常量表达式结果到 VM 寄存器绑定
  } # 结束 ptrtoint 常量表达式 lowering 动作
} # 结束 ptrtoint 常量表达式规则

rule llvm.constexpr.inttoptr { # 将 LLVM inttoptr 常量表达式降低为 profile 驱动的整数转指针
  match %r = llvm.constexpr.inttoptr integer %value # 匹配常量表达式形式的 inttoptr 整数值
  lower { # 开始声明 inttoptr 常量表达式 lowering 动作
    %va = materialize %value as integer # 将常量表达式内部的整数 operand 物化为 VM x 寄存器值
    %vr = vreg ptr # 为 inttoptr 结果分配一个 VM 指针寄存器
    emit zext dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # 窄整数转指针时零扩展到指针宽度
    emit trunc dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # 保留超宽整数安全截断路径，当前 translator 会先按宽度 safe-skip
    emit bitcast dst=%vr, src=%va, from_width=type_width(%value), to_width=type_width(%r) # 同宽 inttoptr 按 bitcast 保留地址 bit
    bind %r = %vr # 记录 inttoptr 常量表达式结果到 VM 寄存器绑定
  } # 结束 inttoptr 常量表达式 lowering 动作
} # 结束 inttoptr 常量表达式规则

rule llvm.freeze.scalar { # 将 LLVM freeze 降低为稳定的 VM 值复制
  match %r = llvm.freeze scalar %value # 匹配整数、指针、float 或 double 标量 freeze
  lower { # 开始声明 freeze lowering 动作
    %vv = materialize %value as scalar # 将待冻结的标量位模式物化为 VM 值
    %vr = vreg scalar # 为 freeze 结果分配一个 VM x 寄存器
    emit mov dst=%vr, src=%vv, width=type_width(%r) # 用 mov 保留非 poison 路径上的原始位模式
    bind %r = %vr # 记录 LLVM freeze 结果到 VM 寄存器的绑定
  } # 结束 freeze lowering 动作
} # 结束 freeze 规则

rule llvm.aggregate.freeze { # 将 LLVM 聚合 freeze 展开为逐字段稳定复制
  match %r = llvm.freeze aggregate %value # 匹配结构体或固定数组聚合 freeze
  lower { # 开始声明聚合 freeze lowering 动作
    %vv = materialize %value as scalar # 将当前聚合叶子字段物化为 VM x 寄存器值
    %vr = vreg scalar # 为冻结后的字段分配新的 VM x 寄存器
    emit mov dst=%vr, src=%vv, width=type_width(%field) # 用 mov 固定该字段的稳定 bit pattern
    bind %r = %vr # 记录当前字段的临时绑定，translator 会把它归入聚合结果
  } # 结束聚合 freeze lowering 动作
} # 结束聚合 freeze 规则

rule llvm.widenable.condition.integer { # 将 LLVM widenable condition 降低为保守恒真的 i1 常量
  match %r = llvm.widenable.condition # 匹配无参数的 llvm.experimental.widenable.condition intrinsic
  lower { # 开始声明 widenable condition lowering 动作
    %vr = vreg integer # 为 i1 结果分配一个 VM x 寄存器
    emit mov_imm dst=%vr, imm=widenable_condition(), width=type_width(%r) # LLVM 允许把该优化提示条件收窄为 true
    bind %r = %vr # 记录 LLVM widenable condition 结果到 VM 寄存器绑定
  } # 结束 widenable condition lowering 动作
} # 结束 widenable condition 规则

rule llvm.allow.runtime.check.integer { # 将 LLVM runtime-check 开关降低为保守允许检查的 i1 常量
  match %r = llvm.allow.runtime.check metadata # 匹配带 metadata 标识的 llvm.allow.runtime.check intrinsic
  lower { # 开始声明 runtime-check 开关 lowering 动作
    %vr = vreg integer # 为 i1 结果分配一个 VM x 寄存器
    emit mov_imm dst=%vr, imm=allow_runtime_check(), width=type_width(%r) # 保守返回 true，避免删除可选运行时检查
    bind %r = %vr # 记录 LLVM runtime-check 开关结果到 VM 寄存器绑定
  } # 结束 runtime-check 开关 lowering 动作
} # 结束 runtime-check 开关规则

rule llvm.allow.ubsan.check.integer { # 将 LLVM UBSan-check 开关降低为保守允许检查的 i1 常量
  match %r = llvm.allow.ubsan.check kind # 匹配带 i8 immarg kind 的 llvm.allow.ubsan.check intrinsic
  lower { # 开始声明 UBSan-check 开关 lowering 动作
    %vr = vreg integer # 为 i1 结果分配一个 VM x 寄存器
    emit mov_imm dst=%vr, imm=allow_ubsan_check(), width=type_width(%r) # 保守返回 true，保留对应 UBSan 检查
    bind %r = %vr # 记录 LLVM UBSan-check 开关结果到 VM 寄存器绑定
  } # 结束 UBSan-check 开关 lowering 动作
} # 结束 UBSan-check 开关规则

rule llvm.objectsize.integer { # 将静态可确定或未知 fallback 的 LLVM objectsize intrinsic 降低为立即数物化
  match %r = llvm.objectsize pointer %ptr # 匹配 translator 已经折叠成常量结果的指针 operand
  lower { # 开始声明 objectsize lowering 动作
    %vr = vreg integer # 为 objectsize 返回值分配一个 VM x 寄存器
