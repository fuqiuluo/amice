rule llvm.vector.bitops.integer { # 将固定整数向量 xor、and、or 拆成逐 lane 位运算
  match %r = llvm.bitop vector integer %a, %b # 匹配由受支持向量操作构造的固定整数向量位运算
  lower { # 开始声明固定整数向量 bitop lowering 动作
    %va = materialize %a_lane as integer # 将当前左侧 lane 物化为 VM 整数值
    %vb = materialize %b_lane as integer # 将当前右侧 lane 物化为 VM 整数值
    %vr = vreg integer # 为当前结果 lane 分配 VM x 寄存器
    emit ixor dst=%vr, lhs=%va, rhs=%vb, width=type_width(%field) # xor 时用 ixor 计算当前 lane
    emit iand dst=%vr, lhs=%va, rhs=%vb, width=type_width(%field) # and 时用 iand 计算当前 lane
    emit ior dst=%vr, lhs=%va, rhs=%vb, width=type_width(%field) # or 时用 ior 计算当前 lane
