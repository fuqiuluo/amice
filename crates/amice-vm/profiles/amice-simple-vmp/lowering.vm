    %vd = materialize object_delta(%ptr) as integer # 取出当前 GEP 相对前序基址的新字节偏移
    %vo = vreg integer # 为新的累计字节偏移分配一个 VM x 寄存器
    emit iadd dst=%vo, lhs=%vp, rhs=%vd, width=64 # 用 previous_offset + delta 得到相对动态 alloca 基址的总偏移
