    %vc = materialize object_count(%ptr) as integer # 取出动态 alloca 保留下来的运行时元素个数
    %ve = materialize object_elem_size(%ptr) as integer # 将单个元素字节数物化为 VM 整数值
    %vr = vreg integer # 为运行时 objectsize 结果分配一个 VM x 寄存器
    emit imul dst=%vr, lhs=%vc, rhs=%ve, width=type_width(%r) # 计算 count * elem_size 并按 intrinsic 返回宽度截断
    bind %r = %vr # 记录 LLVM objectsize 动态结果到 VM 寄存器的绑定
