    bind %r = %vr # 记录 LLVM objectsize 结果到 VM 寄存器的绑定
  } # 结束 objectsize lowering 动作
} # 结束 objectsize 规则

rule llvm.objectsize.static_gep { # 将 static object 上的 dynamic=true GEP objectsize 降低为运行时剩余字节数
  match %r = llvm.objectsize static_gep %ptr # 匹配 translator 已确认总大小静态可知且 GEP offset 运行时可记录的 operand
