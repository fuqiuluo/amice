    emit iadd dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # 用 iadd 合并当前累加值和 lane
    bind %r = %vr # 记录本轮折叠结果，translator 会继续作为下一轮累加值
  } # 结束 fixed vector reduce.add lowering 动作
} # 结束 fixed vector reduce.add 规则

rule llvm.vector.reduce.mul.integer { # 将固定整数向量 reduce.mul 拆成多次 imul 折叠
