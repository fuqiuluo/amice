    %vl = materialize %lane as scalar # 读取 translator 已按 insert 范围定位的源 lane 绑定
    %vr = vreg scalar # 为插入后的目标 lane 分配 VM x 寄存器
    emit mov dst=%vr, src=%vl, width=type_width(%field) # 将基向量或子向量 lane 复制到 insert 结果
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会把它归入向量字段槽
  } # 结束固定向量 subvector insert lowering 动作
} # 结束固定向量 subvector insert 规则

rule llvm.vector.extract.subvector.element { # 将固定向量 llvm.vector.extract 的单个结果 lane 降低为 VM 复制
  match %r = llvm.vector.extract vector %value, imm %offset # 匹配带 i64 immarg 偏移的固定向量 subvector 提取 intrinsic
  lower { # 开始声明固定向量 subvector extract lowering 动作
    %vl = materialize %lane as scalar # 读取 translator 已按 extract 范围定位的源 lane 绑定
    %vr = vreg scalar # 为提取后的目标 lane 分配 VM x 寄存器
    emit mov dst=%vr, src=%vl, width=type_width(%field) # 将源向量 lane 复制到 extract 结果
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会把它归入向量字段槽
  } # 结束固定向量 subvector extract lowering 动作
} # 结束固定向量 subvector extract 规则

rule llvm.vector.interleave.element { # 将固定向量 llvm.vector.interleave2..8 的单个结果 lane 降低为 VM 复制
  match %r = llvm.vector.interleave vectors %values # 匹配固定向量 interleave intrinsic 的多输入 lane 交织
  lower { # 开始声明固定向量 interleave lowering 动作
    %vl = materialize %lane as scalar # 读取 translator 已按交织顺序定位的源 lane 绑定
    %vr = vreg scalar # 为交织后的目标 lane 分配 VM x 寄存器
    emit mov dst=%vr, src=%vl, width=type_width(%field) # 将源 lane 复制到 interleave 结果
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会把它归入向量字段槽
  } # 结束固定向量 interleave lowering 动作
} # 结束固定向量 interleave 规则

rule llvm.vector.deinterleave.element { # 将固定向量 llvm.vector.deinterleave2..8 的单个结果 lane 降低为 VM 复制
  match %r = llvm.vector.deinterleave vector %value # 匹配固定向量 deinterleave intrinsic 的单输入 lane 拆分
  lower { # 开始声明固定向量 deinterleave lowering 动作
    %vl = materialize %lane as scalar # 读取 translator 已按拆分顺序定位的源 lane 绑定
    %vr = vreg scalar # 为拆分后的目标 lane 分配 VM x 寄存器
    emit mov dst=%vr, src=%vl, width=type_width(%field) # 将源 lane 复制到 deinterleave 结果
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会把它归入返回聚合字段槽
  } # 结束固定向量 deinterleave lowering 动作
} # 结束固定向量 deinterleave 规则

rule llvm.experimental.vector.compress.element { # 将固定向量 llvm.experimental.vector.compress 的单个结果 lane 降低为 VM 复制
  match %r = llvm.experimental.vector.compress vector %value, const_mask %mask, vector %passthru # 匹配常量 mask 的固定向量 compress intrinsic
  lower { # 开始声明固定向量 compress lowering 动作
    %vl = materialize %lane as scalar # 读取 translator 已按 compress 规则定位的源 lane 或 passthru lane
    %vr = vreg scalar # 为压缩后的目标 lane 分配 VM x 寄存器
    emit mov dst=%vr, src=%vl, width=type_width(%field) # 将选中的 lane 复制到 compress 结果
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会把它归入向量字段槽
  } # 结束固定向量 compress lowering 动作
} # 结束固定向量 compress 规则

rule llvm.vector.extract.element { # 将固定向量 extractelement 降低为单 lane VM 复制
  match %r = llvm.extractelement vector %vec, const_index %lane # 匹配固定向量的常量 lane 读取
  lower { # 开始声明固定向量 extractelement lowering 动作
    %vl = materialize %lane as scalar # 读取 translator 已定位的向量 lane 绑定
    %vr = vreg scalar # 为读取出的 lane 标量分配 VM x 寄存器
    emit mov dst=%vr, src=%vl, width=type_width(%r) # 将该 lane 复制到 LLVM 标量结果寄存器
    bind %r = %vr # 记录 LLVM extractelement 结果到 VM 寄存器的绑定
  } # 结束固定向量 extractelement lowering 动作
} # 结束固定向量 extractelement 规则

rule llvm.experimental.vector.extract.last.active { # 将 extract.last.active 降低为被选中标量的 VM 复制
  match %r = llvm.experimental.vector.extract.last.active vector %vec, const_mask %mask, %passthru # 匹配常量 mask 的 fixed vector last active 提取
  lower { # 开始声明 extract.last.active lowering 动作
    %vv = materialize %value as scalar # 读取 translator 已按最高 active lane 或 passthru 定位的标量值
    %vr = vreg scalar # 为提取结果分配 VM x 寄存器
    emit mov dst=%vr, src=%vv, width=type_width(%r) # 将选中的 lane 或 passthru 复制到 LLVM 标量结果
    bind %r = %vr # 记录 LLVM extract.last.active 结果到 VM 寄存器的绑定
  } # 结束 extract.last.active lowering 动作
} # 结束 extract.last.active 规则

rule llvm.vector.extract.dynamic_element { # 将动态下标 extractelement 降低为链式 lane 比较
  match %r = llvm.extractelement vector %vec, dynamic_index %lane # 匹配固定向量的运行时 lane 读取
  lower { # 开始声明动态 extractelement lowering 动作
    %vi = materialize %lane as integer # 将运行时 lane 下标物化为 VM 整数寄存器
    %vk = vreg integer # 为当前候选 lane 常量分配 VM 寄存器
    %vm = vreg i1 # 为 lane 命中比较结果分配 VM 布尔寄存器
    %vl = materialize %selected_lane as scalar # 将命中的向量 lane 物化为 VM 标量寄存器
    %vr = vreg scalar # 为 extractelement 标量结果分配 VM 寄存器
    emit mov_imm dst=%vk, imm=lane(%r), width=type_width(%index) # 把当前候选 lane 编号写入比较寄存器
    emit icmp pred=eq, dst=%vm, lhs=%vi, rhs=%vk, width=type_width(%index) # 比较运行时下标是否等于当前 lane
    emit br_if cond=%vm, then_pc=case_label, else_pc=next_case_label # 命中则读取当前 lane，否则继续检查下一 lane
    emit mov dst=%vr, src=%vl, width=type_width(%r) # 将命中的 lane 复制到 LLVM 标量结果寄存器
    emit br target=join_label # 命中后跳过后续 lane 检查
    bind %r = %vr # 记录 LLVM extractelement 结果到 VM 寄存器的绑定
  } # 结束动态 extractelement lowering 动作
} # 结束动态 extractelement 规则

rule llvm.br.control { # 将 LLVM 条件和无条件分支终结指令降低为 VM 控制流
  match llvm.br terminator # 匹配 LLVM br 终结指令
  lower { # 开始声明 br lowering 动作
    %vc = materialize %cond as i1 # 条件分支时将条件物化为 VM 布尔值
    emit br target=target_label # 无条件边发射 br 指令
    emit br_if cond=%vc, then_pc=then_label, else_pc=else_label # 条件边发射 br_if 指令
  } # 结束 br lowering 动作
} # 结束分支规则

rule llvm.switch.control { # 将 LLVM switch 终结指令降低为链式比较和分支
  match llvm.switch terminator # 匹配 LLVM switch 终结指令
  lower { # 开始声明 switch lowering 动作
    %vc = materialize %cond as integer # 将 switch 条件物化为 VM 整数值
    %vk = materialize %case as integer # 将 case 常量物化为 VM 整数值
    %vm = vreg i1 # 为 case 命中结果分配 VM 布尔寄存器
    emit icmp pred=eq, dst=%vm, lhs=%vc, rhs=%vk, width=type_width(%cond) # 每个 case 先发射相等比较
    emit br_if cond=%vm, then_pc=case_label, else_pc=next_case_label # 命中时跳转 case，否则检查下一项
    emit br target=default_label # 未命中任何 case 时跳转默认块
  } # 结束 switch lowering 动作
} # 结束 switch 规则

rule llvm.unreachable { # 将 LLVM unreachable 终结指令降低为 VM 未定义行为终结处理器
  match llvm.unreachable terminator # 匹配 LLVM unreachable terminator
  lower { # 开始声明 unreachable lowering 动作
    emit unreachable # 发射 profile ISA 中的 unreachable 指令
  } # 结束 unreachable lowering 动作
} # 结束 unreachable 规则

rule llvm.trap { # 将 LLVM trap intrinsic 降低为 VM trap 终结处理器
  match llvm.trap intrinsic # 匹配 LLVM trap intrinsic 调用
  lower { # 开始声明 trap lowering 动作
    emit trap # 发射 profile ISA 中的 trap 指令
  } # 结束 trap lowering 动作
} # 结束 trap 规则

rule llvm.ret.scalar { # 将 LLVM 标量整数 return 终结指令降低为 VM 返回
  match llvm.ret scalar %value # 匹配标量或指针返回
  lower { # 开始声明标量返回 lowering 动作
    %vv = materialize %value as integer # 将返回值物化为 VM 值
    emit ret src=%vv # 发射 VM 返回指令
  } # 结束标量返回 lowering 动作
} # 结束标量返回规则

rule llvm.ret.void { # 将 LLVM void return 降低为退出 VM 分派但不读取返回寄存器
  match llvm.ret void # 匹配 void 返回
  lower { # 开始声明 void 返回 lowering 动作
    emit ret src=x0 # 复用 ret 处理器退出分派，wrapper 忽略返回寄存器
  } # 结束 void 返回 lowering 动作
} # 结束 void 返回规则

rule llvm.ret.aggregate { # 将直接结构体返回字段拆分到 ret0..retN ABI 返回槽
  match llvm.ret aggregate %value # 匹配直接聚合返回
  lower { # 开始声明聚合返回 lowering 动作
    %vf = materialize %field as integer # 将每个聚合字段物化为 VM 值
    emit mov dst=ret_slot, src=%vf, width=field_width(%field) # 将字段复制到 ABI 返回槽
    emit ret src=ret0 # 发射 VM 返回指令退出分派
  } # 结束聚合返回 lowering 动作
} # 结束聚合返回规则

rule llvm.ret.sret { # 将 sret 形式的结构体返回写入宿主 ABI 提供的返回指针
  match llvm.ret sret %ptr # 匹配带 sret 返回缓冲区的 void 返回函数
  lower { # 开始声明 sret 返回 lowering 动作
    %vp = materialize %ptr as ptr # 将 sret 返回缓冲区物化为 VM 指针值
    %vf = materialize %field as integer # 将待写回字段物化为 VM 值
    emit store src=%vf, ptr=%vp, width=field_width(%field) # 将聚合字段写回宿主 ABI 返回缓冲区
    emit ret src=x0 # 发射 VM 返回指令退出分派
  } # 结束 sret lowering 动作
} # 结束 sret 返回规则

rule llvm.phi.edge_move { # 将 LLVM phi 规范化为前驱边上的 VM move
  match %r = llvm.phi edge %incoming # 匹配 phi 的前驱边输入
  lower { # 开始声明 phi edge lowering 动作
    %vi = materialize %incoming as integer # 将前驱边输入物化为 VM 值
    %vr = vreg integer # 复用 phi 目标的 VM 寄存器
    emit mov dst=%vr, src=%vi, width=type_width(%r) # 在前驱边发射 mov 物化 phi 结果
    bind %r = %vr # 记录 phi 结果到 VM 寄存器的绑定
  } # 结束 phi edge lowering 动作
} # 结束 phi 规则

rule llvm.aggregate.phi.edge_move { # 将 LLVM 聚合 phi 规范化为前驱边上的逐字段 VM move
  match %r = llvm.phi aggregate edge %incoming # 匹配结构体或固定数组聚合 phi 的前驱边输入
  lower { # 开始声明聚合 phi edge lowering 动作
    %vi = materialize %incoming_field as scalar # 将当前前驱边叶子字段物化为 VM 值
    %vr = vreg scalar # 复用当前 phi 结果叶子字段的 VM 寄存器
    emit mov dst=%vr, src=%vi, width=type_width(%field) # 在前驱边复制当前叶子字段
    bind %r = %vr # 记录当前叶子字段临时绑定，translator 会保持聚合结果绑定
  } # 结束聚合 phi edge lowering 动作
} # 结束聚合 phi 规则

rule llvm.vector.phi.edge_move { # 将固定向量 phi 规范化为前驱边上的逐 lane VM move
  match %r = llvm.phi vector edge %incoming # 匹配固定向量 phi 的前驱边输入
  lower { # 开始声明固定向量 phi edge lowering 动作
    %vi = materialize %incoming_field as scalar # 将当前前驱边 lane 物化为 VM 值
    %vr = vreg scalar # 复用当前 phi 结果 lane 的 VM 寄存器
    emit mov dst=%vr, src=%vi, width=type_width(%field) # 在前驱边复制当前 lane
    bind %r = %vr # 记录当前 lane 临时绑定，translator 会保持固定向量结果绑定
  } # 结束固定向量 phi edge lowering 动作
} # 结束固定向量 phi 规则
