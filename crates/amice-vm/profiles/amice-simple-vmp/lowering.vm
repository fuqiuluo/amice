rule llvm.add.integer { # 将 LLVM 整数 add 降低为 iadd VM 指令
  match %r = llvm.add integer %a, %b # 匹配任意受支持整数宽度的 LLVM add
  lower { # 开始声明 add 的 lowering 动作
    %va = materialize %a as integer # 将左操作数物化为 VM 整数值
    %vb = materialize %b as integer # 将右操作数物化为 VM 整数值
    %vr = vreg integer # 为 add 结果分配一个 VM x 寄存器
    emit iadd dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # 发射 profile ISA 中的 iadd 指令
    bind %r = %vr # 记录 LLVM 结果到 VM 寄存器的绑定
  } # 结束 add lowering 动作
} # 结束 add 规则

rule llvm.sub.integer { # 将 LLVM 整数 sub 降低为 isub VM 指令
  match %r = llvm.sub integer %a, %b # 匹配任意受支持整数宽度的 LLVM sub
  lower { # 开始声明 sub 的 lowering 动作
    %va = materialize %a as integer # 将左操作数物化为 VM 整数值
    %vb = materialize %b as integer # 将右操作数物化为 VM 整数值
    %vr = vreg integer # 为 sub 结果分配一个 VM x 寄存器
    emit isub dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # 发射 profile ISA 中的 isub 指令
    bind %r = %vr # 记录 LLVM 结果到 VM 寄存器的绑定
  } # 结束 sub lowering 动作
} # 结束 sub 规则

rule llvm.loop.decrement.reg.integer { # 将 LLVM loop.decrement.reg intrinsic 降低为 isub VM 指令
  match %r = llvm.loop.decrement.reg integer %a, %b # 匹配硬件循环寄存器计数的剩余迭代数计算
  lower { # 开始声明 loop.decrement.reg 的 lowering 动作
    %va = materialize %a as integer # 将循环计数器物化为 VM 整数值
    %vb = materialize %b as integer # 将本次迭代步长物化为 VM 整数值
    %vr = vreg integer # 为剩余迭代数结果分配一个 VM x 寄存器
    emit isub dst=%vr, lhs=%va, rhs=%vb, width=type_width(%r) # 发射 profile ISA 中的 isub 指令
    bind %r = %vr # 记录 LLVM 结果到 VM 寄存器的绑定
  } # 结束 loop.decrement.reg lowering 动作
} # 结束 loop.decrement.reg 规则

rule llvm.loop.decrement.integer { # 将 LLVM loop.decrement intrinsic 降低为“递减后是否非零”的 VM 指令序列
  match %r = llvm.loop.decrement integer %counter # 匹配返回 i1 的单参数硬件循环递减条件 intrinsic
  lower { # 开始声明 loop.decrement 的 lowering 动作
    %vc = materialize %counter as integer # 将循环计数器物化为 VM 整数值
    %one = vreg integer # 为常量 1 分配一个 VM x 寄存器
    %zero = vreg integer # 为常量 0 分配一个 VM x 寄存器
    %remaining = vreg integer # 为 counter - 1 的剩余计数分配一个 VM x 寄存器
    %vr = vreg i1 # 为“剩余计数非零”的 i1 结果分配一个 VM x 寄存器
    emit mov_imm dst=%one, imm=1, width=type_width(%counter) # 物化 loop.decrement 的固定递减步长 1
